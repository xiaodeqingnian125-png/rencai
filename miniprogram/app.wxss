page {
  min-height: 100%;
  background: #fafaf6;
  color: #2d2318;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
}

.section {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d2318;
}

.section-more {
  font-size: 24rpx;
  color: #8c7a68;
}

.card {
  background: #fffdf7;
  border: 1rpx solid #f0eae0;
  border-radius: 24rpx;
}

.muted {
  color: #8c7a68;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e8e0d4;
  color: #8c7a68;
  background: transparent;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-hot {
  border-color: #f0b693;
  background: #fdf0e8;
  color: #e8590c;
}

.tag-new {
  border-color: #f3b697;
  background: #fff0e7;
  color: #e8723c;
}

.tag-subway,
.tag-blue {
  border-color: #b9cfdf;
  background: #edf5fa;
  color: #5b8cb8;
}

.tag-warm {
  background: #fff0df;
  color: #d76924;
}

.primary-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: #e8723c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.ghost-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  padding: 0 28rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  color: #5c4a38;
  font-size: 26rpx;
  font-weight: 600;
  background: #fffdf7;
}

.empty-state {
  padding: 88rpx 28rpx;
  text-align: center;
  color: #8c7a68;
}

.empty-title {
  display: block;
  margin-bottom: 10rpx;
  color: #2d2318;
  font-size: 30rpx;
  font-weight: 700;
}
