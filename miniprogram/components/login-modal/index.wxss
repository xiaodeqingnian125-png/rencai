.login-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(45, 35, 24, 0.45);
  animation: overlay-fade-in 150ms cubic-bezier(0.28, 0, 0.22, 1) both;
}

.login-card {
  width: 86%;
  max-width: 620rpx;
  padding: 48rpx 40rpx 36rpx;
  border-radius: 36rpx;
  background: #fffdf7;
  animation: center-pop-in 220ms cubic-bezier(0.28, 0, 0.22, 1) both;
}

.login-title {
  color: #2d2318;
  font-size: 40rpx;
  font-weight: 650;
  text-align: center;
}

.login-subtitle {
  margin-top: 12rpx;
  color: #8c7a68;
  font-size: 26rpx;
  text-align: center;
  line-height: 1.5;
}

.field-group {
  margin-top: 36rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #5c4a38;
  font-size: 26rpx;
  font-weight: 600;
}

.field-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 20rpx;
  background: #fafaf6;
  color: #2d2318;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: border-color 150ms cubic-bezier(0.28, 0, 0.22, 1);
}

.field-input:focus {
  border-color: #e8723c;
}

/* 微信获取模式：input 视觉层 + 透明 button 覆盖层 */
.phone-wechat-wrap {
  position: relative;
  width: 100%;
}

/* 只读 input 作为视觉层，样式完全继承 .field-input */
.phone-wechat-input {
  background: #fafaf6;
}

/* input 禁用态会变灰，这里覆盖回正常颜色 */
.phone-wechat-input[disabled] {
  color: #2d2318;
  opacity: 1;
}

.phone-wechat-input.is-placeholder {
  color: #b5a99a;
}

/* 透明 button 覆盖在 input 之上，负责触发 getPhoneNumber */
.phone-wechat-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  opacity: 0;
  z-index: 2;
}

.phone-wechat-overlay::after {
  border: 0;
  content: none;
}

.phone-toggle {
  margin-top: 12rpx;
  color: #e8723c;
  font-size: 24rpx;
  text-align: right;
  transition: opacity 150ms cubic-bezier(0.28, 0, 0.22, 1);
}

.phone-toggle:active {
  opacity: 0.6;
}

.login-tips {
  margin-top: 24rpx;
  color: #a69682;
  font-size: 24rpx;
  line-height: 1.5;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 92rpx;
  margin-top: 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e8723c 0%, #e8590c 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 650;
  transition: transform 150ms cubic-bezier(0.28, 0, 0.22, 1), opacity 150ms cubic-bezier(0.28, 0, 0.22, 1);
}

.login-btn:active {
  transform: scale(0.98);
  opacity: 0.88;
}

.login-btn::after {
  border: 0;
}

.login-cancel {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 80rpx;
  margin-top: 16rpx;
  background: transparent;
  color: #8c7a68;
  font-size: 28rpx;
  transition: opacity 150ms cubic-bezier(0.28, 0, 0.22, 1);
}

.login-cancel:active {
  opacity: 0.6;
}

.login-cancel::after {
  border: 0;
}
