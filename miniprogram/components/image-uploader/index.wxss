.uploader {
  width: 100%;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 100%;
  height: 200rpx;
  border: 2rpx dashed #d4c5b0;
  border-radius: 24rpx;
  background: #fafaf6;
  transition: border-color 150ms cubic-bezier(0.28, 0, 0.22, 1), background 150ms cubic-bezier(0.28, 0, 0.22, 1);
}

.upload-btn:active {
  border-color: #e8723c;
  background: #fef8ef;
}

.upload-icon {
  font-size: 56rpx;
  color: #a69682;
  line-height: 1;
}

.upload-text {
  color: #5c4a38;
  font-size: 28rpx;
  font-weight: 500;
}

.upload-hint {
  color: #a69682;
  font-size: 24rpx;
}

.preview-wrap {
  position: relative;
  width: 100%;
  height: 200rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f0eae0;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.preview-actions {
  position: absolute;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 8rpx;
  padding: 16rpx;
}

.preview-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: opacity 150ms cubic-bezier(0.28, 0, 0.22, 1);
}

.preview-btn:active {
  opacity: 0.7;
}

.preview-btn.replace {
  background: rgba(232, 114, 60, 0.9);
  color: #fffdf7;
}

.preview-btn.remove {
  background: rgba(45, 35, 24, 0.6);
  color: #fffdf7;
}
