.plans-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 32rpx 56rpx;
  background: #fafaf6;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.plan-item {
  overflow: hidden;
  border: 1rpx solid #f0eae0;
  border-radius: 24rpx;
  background: #fffdf7;
}

.plan-image {
  display: block;
  width: 100%;
  background: #f6f2eb;
}

.plan-caption {
  padding: 20rpx 24rpx 22rpx;
  color: #5c4a38;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.45;
  text-align: center;
}

.plans-state {
  display: flex;
  min-height: 68vh;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8c7a68;
  font-size: 26rpx;
  text-align: center;
}

.state-title {
  margin-bottom: 14rpx;
  color: #2d2318;
  font-size: 32rpx;
  font-weight: 750;
}

.plans-state button {
  width: 230rpx;
  height: 72rpx;
  margin-top: 30rpx;
  border-radius: 999rpx;
  background: #e8723c;
  color: #fff;
  font-size: 26rpx;
  line-height: 72rpx;
}
