.admin-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  min-height: 100vh;
  background: #fafaf6;
}

button::after {
  border: none;
}

.admin-page.apartment-mode {
  overflow: hidden;
}

.admin-state {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 70vh;
  padding: 64rpx 56rpx;
  color: #8c7a68;
  text-align: center;
}

.admin-state-title {
  margin-bottom: 16rpx;
  color: #2d2318;
  font-size: 34rpx;
  font-weight: 800;
}

.admin-state text {
  max-width: 560rpx;
  font-size: 27rpx;
  line-height: 1.7;
}

.admin-state button {
  width: 240rpx;
  height: 72rpx;
  margin-top: 32rpx;
  border-radius: 999rpx;
  background: #e8723c;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.preview-badge {
  margin-bottom: 24rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #fff0e7;
  color: #d4622c;
  font-size: 23rpx;
  font-weight: 700;
}

.apartment-admin {
  display: flex;
  flex-direction: column;
  height: 100vh;
  min-height: 100vh;
  background: #fafaf6;
}

.apartment-toolbar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx 32rpx;
  flex-shrink: 0;
}

.apartment-search {
  display: flex;
  flex: 1;
  width: 0;
  align-items: center;
  min-width: 0;
  height: 76rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 24rpx;
  background: #fffdf7;
}

.apartment-search image {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  opacity: 0.78;
}

.apartment-search input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  color: #2d2318;
  font-size: 28rpx;
}

.apartment-add {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 138rpx;
  height: 76rpx;
  margin-left: 16rpx;
  padding: 0;
  border-radius: 24rpx;
  background: #e8723c;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.bulk-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
  flex-shrink: 0;
}

.room-bulk-bar {
  padding-top: 0;
}

.bulk-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-width: 0;
  height: 64rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 20rpx;
  background: #fffdf7;
  color: #5c4a38;
  font-size: 25rpx;
  font-weight: 650;
  line-height: 1;
  white-space: nowrap;
}

.bulk-btn.primary {
  border-color: rgba(232, 114, 60, 0.36);
  background: #fff0e7;
  color: #d4622c;
}

.apartment-scroll {
  flex: 1;
  min-height: 0;
  height: auto;
}

.apartment-list {
  display: flex;
  flex-direction: column;
  padding: 0 32rpx 44rpx;
}

.apartment-card {
  margin-bottom: 22rpx;
  padding: 32rpx 32rpx 30rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 32rpx;
  background: #fffdf7;
}

.apartment-card:last-child {
  margin-bottom: 0;
}

.apartment-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.apartment-name {
  flex: 1;
  width: 0;
  min-width: 0;
  margin-right: 18rpx;
  padding-top: 4rpx;
  color: #2d2318;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.28;
}

.apartment-actions {
  display: flex;
  align-items: center;
  width: 208rpx;
  flex-shrink: 0;
}

.apartment-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 98rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #5c4a38;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
}

.apartment-btn.danger {
  margin-left: 12rpx;
  border-color: rgba(224, 74, 58, 0.34);
  color: #e04a3a;
}

.apartment-meta {
  display: flex;
  flex-direction: column;
  color: #8c7a68;
  font-size: 26rpx;
  line-height: 1.45;
}

.apartment-meta text {
  display: block;
}

.apartment-status {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  margin-top: 16rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.apartment-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
  color: #8c7a68;
  font-size: 28rpx;
}

.apartment-empty view {
  color: #e8e0d4;
  font-size: 84rpx;
}

