.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  background: rgba(45, 35, 24, 0.32);
  animation: overlay-fade-in 150ms cubic-bezier(0.28, 0, 0.22, 1) both;
}

.modal-card {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  max-height: 84vh;
  padding: 28rpx 36rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 48rpx 48rpx 0 0;
  background: #fafaf6;
  box-shadow: 0 -24rpx 72rpx rgba(45, 35, 24, 0.18);
  animation: sheet-slide-up 220ms cubic-bezier(0.28, 0, 0.22, 1) both;
}

.import-card {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 14vh;
  z-index: 90;
  display: flex;
  flex-direction: column;
  max-height: 72vh;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fffdf7;
  box-shadow: 0 28rpx 90rpx rgba(45, 35, 24, 0.18);
}

.import-textarea {
  width: 100%;
  min-height: 360rpx;
  max-height: 46vh;
  box-sizing: border-box;
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 24rpx;
  background: #fafaf6;
  color: #2d2318;
  font-size: 24rpx;
  line-height: 1.5;
}

.import-hint {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff0e7;
  color: #8c4a2c;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.45;
}

.import-error {
  margin-top: 16rpx;
  color: #e04a3a;
  font-size: 24rpx;
  line-height: 1.35;
}

.modal-head {
  padding-bottom: 22rpx;
  text-align: center;
}

.modal-title {
  color: #2d2318;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.modal-subtitle {
  margin-top: 8rpx;
  color: #8c7a68;
  font-size: 24rpx;
  line-height: 1.35;
}

.modal-fields {
  max-height: 54vh;
  padding-right: 2rpx;
}

.modal-field {
  display: grid;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.modal-field text {
  color: #8c7a68;
  font-size: 24rpx;
  font-weight: 600;
}

.modal-field input,
.modal-field textarea {
  min-height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 18rpx;
  background: #fffdf7;
  color: #2d2318;
  font-size: 28rpx;
}

.modal-field textarea {
  height: 144rpx;
  padding-top: 20rpx;
  line-height: 1.45;
}

.status-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.status-options view {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: auto;
  height: 58rpx;
  margin: 0;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  color: #5c4a38;
  font-size: 24rpx;
  line-height: 1;
  white-space: nowrap;
}

.status-options view.active {
  border-color: #e8723c;
  background: #e8723c;
  color: #ffffff;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.modal-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 80rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 650;
}

.modal-btn.cancel {
  background: #fffdf7;
  color: #5c4a38;
}

.modal-btn.confirm {
  background: #e8723c;
  color: #ffffff;
}

.modal-btn.delete {
  background: #e04a3a;
  color: #ffffff;
}

/* ===== 任务 18：导入历史入口 + 按条件导出 UI ===== */
.admin-action-row {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 32rpx;
}

.admin-btn {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  background: #fffdf7;
  border: 1rpx solid #e8723c;
  color: #e8723c;
  font-size: 26rpx;
  border-radius: 32rpx;
}

.export-filter {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  flex-wrap: wrap;
}

.filter-label {
  font-size: 24rpx;
  color: #8c7a68;
}

.filter-picker {
  padding: 8rpx 20rpx;
  background: #fffdf7;
  border: 1rpx solid #f0eae0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #2d2318;
}

.export-btn {
  padding: 8rpx 24rpx;
  background: #e8723c;
  color: #fff;
  font-size: 24rpx;
  border-radius: 8rpx;
  line-height: 1.5;
}

/* ===== 批量导出弹窗（按条件导出并入弹窗） ===== */
.export-card {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 14vh;
  z-index: 90;
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fffdf7;
  box-shadow: 0 28rpx 90rpx rgba(45, 35, 24, 0.18);
}

.export-panel-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 16rpx;
}

.export-panel-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.export-panel-row text {
  flex: 0 0 auto;
  width: 80rpx;
  color: #8c7a68;
  font-size: 26rpx;
  font-weight: 600;
}

.export-panel-row .filter-picker {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
}

.floor-plan-editor {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #f0eae0;
}

.floor-plan-editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.floor-plan-editor-title,
.floor-plan-editor-tip {
  display: block;
}

.floor-plan-editor-title {
  color: #2d2318;
  font-size: 28rpx;
  font-weight: 750;
}

.floor-plan-editor-tip {
  margin-top: 6rpx;
  color: #a08d79;
  font-size: 22rpx;
}

.floor-plan-add {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff0e7;
  color: #d4622c;
  font-size: 24rpx;
  font-weight: 700;
}

.floor-plan-editor-empty {
  padding: 32rpx 20rpx;
  border: 1rpx dashed #e8e0d4;
  border-radius: 20rpx;
  color: #a08d79;
  font-size: 24rpx;
  text-align: center;
}

.floor-plan-editor-item {
  margin-bottom: 20rpx;
  padding: 22rpx;
  border: 1rpx solid #eee5da;
  border-radius: 22rpx;
  background: #fffaf2;
}

.floor-plan-editor-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.floor-plan-editor-row text {
  flex: 0 0 auto;
  margin-right: 16rpx;
  color: #6e5b48;
  font-size: 24rpx;
}

.floor-plan-editor-row input {
  flex: 1;
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #2d2318;
  font-size: 25rpx;
}

.floor-plan-editor-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 16rpx;
}

.floor-plan-editor-actions view {
  padding: 9rpx 18rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  color: #6e5b48;
  font-size: 23rpx;
}

.floor-plan-editor-actions .danger {
  border-color: rgba(224, 74, 58, 0.3);
  color: #e04a3a;
}
