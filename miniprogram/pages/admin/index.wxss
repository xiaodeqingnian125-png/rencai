.admin-page {
  min-height: 100vh;
  background: #fafaf6;
}

.toolbar {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 16rpx;
}

.search-box {
  display: flex;
  flex: 1;
  align-items: center;
  gap: 16rpx;
  height: 76rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 24rpx;
  background: #fffdf7;
}

.search-box image {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.search-box input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  color: #2d2318;
  font-size: 28rpx;
}

.btn-add {
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: #e8723c;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 650;
  white-space: nowrap;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  padding: 0 32rpx 16rpx;
}

.filter-chip {
  flex-shrink: 0;
  height: 54rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  color: #5c4a38;
  font-size: 24rpx;
  font-weight: 500;
}

.filter-chip.active {
  border-color: #e8723c;
  background: #e8723c;
  color: #ffffff;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 0 32rpx 20rpx;
}

.summary-card {
  padding: 20rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 24rpx;
  background: #fffdf7;
}

.summary-value {
  color: #2d2318;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
}

.summary-card text {
  display: block;
  margin-top: 10rpx;
  color: #8c7a68;
  font-size: 22rpx;
}

.admin-scroll {
  height: calc(100vh - 242rpx);
}

.admin-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 8rpx 32rpx 40rpx;
}

.admin-item {
  padding: 28rpx 32rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 36rpx;
  background: #fffdf7;
}

.item-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.item-title-wrap {
  flex: 1;
  min-width: 0;
}

.item-name {
  color: #2d2318;
  font-size: 32rpx;
  font-weight: 650;
  line-height: 1.35;
}

.item-meta,
.item-desc {
  margin-top: 8rpx;
  color: #8c7a68;
  font-size: 26rpx;
  line-height: 1.45;
}

.item-desc {
  color: #5c4a38;
}

.status {
  flex-shrink: 0;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 650;
  line-height: 42rpx;
}

.status-on {
  background: rgba(91, 154, 111, 0.12);
  color: #5b9a6f;
}

.status-warn {
  background: rgba(232, 89, 12, 0.12);
  color: #e8590c;
}

.status-off {
  background: rgba(140, 122, 104, 0.12);
  color: #8c7a68;
}

.item-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.btn-sm {
  height: 54rpx;
  padding: 0 22rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #5c4a38;
  font-size: 24rpx;
  font-weight: 500;
}

.btn-sm.primary {
  border-color: rgba(232, 114, 60, 0.36);
  color: #d4622c;
}

.btn-sm.danger {
  border-color: rgba(224, 74, 58, 0.3);
  color: #e04a3a;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 128rpx 40rpx;
  color: #8c7a68;
  font-size: 28rpx;
}

.empty view {
  color: #e8e0d4;
  font-size: 84rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  background: rgba(45, 35, 24, 0.32);
}

.modal-card {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  z-index: 90;
  max-height: 82vh;
  padding: 36rpx;
  border-radius: 36rpx;
  background: #fafaf6;
  transform: translateY(-50%);
  box-shadow: 0 24rpx 72rpx rgba(45, 35, 24, 0.18);
}

.modal-title {
  margin-bottom: 28rpx;
  color: #2d2318;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
}

.modal-fields {
  max-height: 54vh;
}

.modal-field {
  display: grid;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.modal-field text {
  color: #8c7a68;
  font-size: 24rpx;
  font-weight: 600;
}

.modal-field input,
.modal-field textarea {
  min-height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 18rpx;
  background: #fffdf7;
  color: #2d2318;
  font-size: 28rpx;
}

.modal-field textarea {
  height: 144rpx;
  padding-top: 20rpx;
  line-height: 1.45;
}

.status-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.status-options button {
  height: 54rpx;
  padding: 0 22rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  color: #5c4a38;
  font-size: 24rpx;
}

.status-options button.active {
  border-color: #e8723c;
  background: #e8723c;
  color: #ffffff;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.modal-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 80rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 650;
}

.modal-btn.cancel {
  background: #fffdf7;
  color: #5c4a38;
}

.modal-btn.confirm {
  background: #e8723c;
  color: #ffffff;
}

.modal-btn.delete {
  background: #e04a3a;
  color: #ffffff;
}
