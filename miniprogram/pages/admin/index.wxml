<view class="admin-page {{isApartment ? 'apartment-mode' : ''}}">
  <view wx:if="{{loading}}" class="admin-state">
    <view class="admin-state-title">正在加载{{config.title}}</view>
    <text>请稍候</text>
  </view>

  <view wx:elif="{{loadError}}" class="admin-state error">
    <view class="admin-state-title">数据加载失败</view>
    <text>{{loadError}}</text>
    <button bindtap="retryLoad">重新加载</button>
  </view>

  <view wx:elif="{{previewOnly}}" class="admin-state preview">
    <view class="preview-badge">功能预览 · 即将开放</view>
    <view class="admin-state-title">{{config.title}}暂未开放</view>
    <text>当前版本优先上线公寓和户型管理，本模块保留入口供后续迭代。</text>
  </view>

  <block wx:elif="{{isApartment}}">
    <view class="apartment-admin">
      <view class="apartment-toolbar">
        <view class="apartment-search">
          <image src="/assets/icons/search.svg" mode="aspectFit"></image>
          <input value="{{keyword}}" placeholder="{{config.search}}" bindinput="handleSearch" />
        </view>
        <view class="add-icon-btn" bindtap="openForm">＋</view>
      </view>
      <view class="bulk-bar">
        <view class="bulk-btn" bindtap="openExportPanel">批量导出</view>
        <view class="bulk-btn primary" bindtap="openImport">批量导入</view>
        <view class="bulk-btn" bindtap="goImportHistory" data-type="apartments">导入历史</view>
      </view>

      <scroll-view scroll-y class="apartment-scroll">
        <view wx:if="{{visibleItems.length}}" class="apartment-list">
          <view wx:for="{{visibleItems}}" wx:key="id" class="apartment-card">
            <view class="apartment-card-head">
              <view class="apartment-name">{{item.title}}</view>
              <view class="apartment-actions">
                <view class="apartment-btn" data-id="{{item.id}}" bindtap="openForm">编辑</view>
                <view class="apartment-btn danger" data-id="{{item.id}}" bindtap="deleteItem">删除</view>
              </view>
            </view>
            <view class="apartment-meta">
              <text>{{item.apartmentAddress}}</text>
              <text>{{item.apartmentRent}}</text>
              <text>{{item.apartmentFacility}}</text>
            </view>
            <text class="apartment-status {{item.statusClass}}">{{item.statusLabel}}</text>
          </view>
        </view>
        <view wx:else class="apartment-empty">
          <view>⌕</view>
          <text>暂无公寓数据</text>
        </view>
      </scroll-view>
    </view>
  </block>

  <block wx:elif="{{isRoom}}">
    <view class="room-admin">
      <view class="room-toolbar">
        <view class="room-search">
          <image src="/assets/icons/search.svg" mode="aspectFit"></image>
          <input value="{{keyword}}" placeholder="{{config.search}}" bindinput="handleSearch" />
        </view>
        <view class="add-icon-btn" bindtap="openForm">＋</view>
      </view>
      <view class="bulk-bar">
        <view class="bulk-btn" bindtap="openExportPanel">批量导出</view>
        <view class="bulk-btn primary" bindtap="openImport">批量导入</view>
        <view class="bulk-btn" bindtap="goImportHistory" data-type="room_types">导入历史</view>
      </view>

      <scroll-view scroll-y class="room-scroll">
        <view wx:if="{{visibleItems.length}}" class="room-list">
          <view wx:for="{{visibleItems}}" wx:key="id" class="room-card">
            <view class="room-card-head">
              <view class="room-name">{{item.title}}</view>
              <view class="room-actions">
                <view class="room-btn" data-id="{{item.id}}" bindtap="openForm">编辑</view>
                <view class="room-btn danger" data-id="{{item.id}}" bindtap="deleteItem">删除</view>
              </view>
            </view>
            <view class="room-apartment">{{item.roomApartment}}</view>
            <view class="room-meta">{{item.roomMeta}}</view>
            <text class="room-status {{item.statusClass}}">{{item.statusLabel}}</text>
          </view>
        </view>
        <view wx:else class="empty">
          <view>⌕</view>
          <text>暂无户型数据</text>
        </view>
      </scroll-view>
    </view>
  </block>

  <block wx:else>
    <view class="shared-admin">
      <view class="shared-toolbar">
        <view class="shared-search">
          <image src="/assets/icons/search.svg" mode="aspectFit"></image>
          <input value="{{keyword}}" placeholder="{{config.search}}" bindinput="handleSearch" />
        </view>
        <view class="shared-add" bindtap="openForm">{{config.addText}}</view>
      </view>

      <scroll-view scroll-x class="shared-filter-scroll" show-scrollbar="{{false}}">
        <view class="shared-filter-row">
          <view
            wx:for="{{config.filters}}"
            wx:key="value"
            class="shared-filter-chip {{activeFilter === item.value ? 'active' : ''}}"
            data-value="{{item.value}}"
            bindtap="setFilter"
          >{{item.label}}</view>
        </view>
      </scroll-view>

      <view class="shared-summary-grid">
        <view class="shared-summary-card">
          <view class="shared-summary-value">{{summary.total}}</view>
          <text>{{summary.totalLabel}}</text>
        </view>
        <view class="shared-summary-card">
          <view class="shared-summary-value">{{summary.pending}}</view>
          <text>{{summary.pendingLabel}}</text>
        </view>
        <view class="shared-summary-card">
          <view class="shared-summary-value">{{summary.active}}</view>
          <text>{{summary.activeLabel}}</text>
        </view>
      </view>

      <scroll-view scroll-y class="shared-scroll">
        <view wx:if="{{visibleItems.length}}" class="shared-list">
          <view wx:for="{{visibleItems}}" wx:key="id" class="shared-card">
            <view class="shared-card-head">
              <view class="shared-title-wrap">
                <view class="shared-name">{{item.title}}</view>
                <view class="shared-meta">{{item.meta}}</view>
              </view>
              <text class="shared-status {{item.statusClass}}">{{item.statusLabel}}</text>
            </view>
            <view class="shared-desc">
              <text wx:for="{{item.descLines}}" wx:key="*this">{{item}}</text>
            </view>
            <view class="shared-actions">
              <view class="shared-btn primary" data-id="{{item.id}}" bindtap="openForm">编辑</view>
              <view
                class="shared-btn"
                data-id="{{item.id}}"
                data-status="{{item.primaryAction.status}}"
                data-toast="{{item.primaryAction.toast}}"
                bindtap="updateStatus"
              >{{item.primaryAction.label}}</view>
              <view
                class="shared-btn"
                data-id="{{item.id}}"
                data-status="{{item.secondaryAction.status}}"
                data-toast="{{item.secondaryAction.toast}}"
                bindtap="updateStatus"
              >{{item.secondaryAction.label}}</view>
              <view class="shared-btn danger" data-id="{{item.id}}" bindtap="deleteItem">删除</view>
            </view>
          </view>
        </view>
        <view wx:else class="empty">
          <view>⌕</view>
          <text>暂无匹配记录</text>
        </view>
      </scroll-view>
    </view>
  </block>

  <view wx:if="{{formOpen && !previewOnly}}" class="modal-mask" catchtap="closeForm"></view>
  <view wx:if="{{formOpen && !previewOnly}}" class="modal-card">
    <view class="modal-head">
      <view class="modal-title">{{editingId ? config.editTitle : config.addTitle}}</view>
      <view class="modal-subtitle">{{config.title}} · {{editingId ? '更新当前内容' : '创建新记录'}}</view>
    </view>
    <scroll-view scroll-y class="modal-fields">
      <view wx:for="{{config.fields}}" wx:key="key" class="modal-field">
        <text>{{item.label}}</text>
        <textarea
          wx:if="{{item.type === 'textarea'}}"
          data-key="{{item.key}}"
          value="{{form[item.key]}}"
          placeholder="{{item.placeholder}}"
          bindinput="handleFieldInput"
        ></textarea>
        <input
          wx:else
          data-key="{{item.key}}"
          value="{{form[item.key]}}"
          placeholder="{{item.placeholder}}"
          bindinput="handleFieldInput"
        />
      </view>
      <view wx:if="{{config.supportImage}}" class="modal-field">
        <text>封面图</text>
        <image-uploader
          value="{{form.image}}"
          label="上传封面图"
          cloud-path="{{config.cloudPath}}"
          bind:change="onImageChange"
        ></image-uploader>
      </view>
      <view wx:if="{{isApartment}}" class="floor-plan-editor">
        <view class="floor-plan-editor-head">
          <view>
            <text class="floor-plan-editor-title">平面图</text>
            <text class="floor-plan-editor-tip">按当前顺序展示，详情页显示前3张</text>
          </view>
          <view class="floor-plan-add" bindtap="addFloorPlan">＋ 添加</view>
        </view>
        <view wx:if="{{!form.floor_plans.length}}" class="floor-plan-editor-empty">暂未添加平面图</view>
        <view wx:for="{{form.floor_plans}}" wx:key="index" class="floor-plan-editor-item">
          <view class="floor-plan-editor-row">
            <text>图片名称</text>
            <input
              value="{{item.name}}"
              placeholder="如：项目总平面图"
              data-index="{{index}}"
              bindinput="handleFloorPlanNameInput"
            />
          </view>
          <image-uploader
            value="{{item.image}}"
            label="上传平面图"
            cloud-path="floor-plans/apartments"
            index="{{index}}"
            bind:change="onFloorPlanImageChange"
          ></image-uploader>
          <view class="floor-plan-editor-actions">
            <view data-index="{{index}}" data-direction="-1" bindtap="moveFloorPlan">上移</view>
            <view data-index="{{index}}" data-direction="1" bindtap="moveFloorPlan">下移</view>
            <view class="danger" data-index="{{index}}" bindtap="removeFloorPlan">删除</view>
          </view>
        </view>
      </view>
      <view class="modal-field">
        <text>状态</text>
        <view class="status-options">
          <block wx:for="{{config.statusOptions}}" wx:key="value">
            <view
              class="{{form.status === item.value ? 'active' : ''}}"
              data-value="{{item.value}}"
              bindtap="setFormStatus"
            >{{item.label}}</view>
          </block>
        </view>
      </view>
    </scroll-view>
    <view class="modal-actions">
      <button class="modal-btn cancel" bindtap="closeForm" disabled="{{operationPending}}">取消</button>
      <button wx:if="{{editingId}}" class="modal-btn delete" data-id="{{editingId}}" bindtap="deleteItem" disabled="{{operationPending}}">删除</button>
      <button class="modal-btn confirm" bindtap="saveItem" loading="{{operationPending}}" disabled="{{operationPending}}">保存</button>
    </view>
  </view>

  <view wx:if="{{importOpen}}" class="modal-mask" catchtap="closeImport"></view>
  <view wx:if="{{importOpen}}" class="import-card">
    <view class="modal-head">
      <view class="modal-title">{{config.title}}批量导入</view>
      <view class="modal-subtitle">从 Excel / WPS / 飞书表格复制后粘贴，按 ID 合并新增或更新</view>
    </view>
    <view class="import-hint">列顺序：{{importHint}}</view>
    <textarea
      class="import-textarea"
      value="{{importDraft}}"
      placeholder="粘贴表格内容，第一行需要包含表头"
      bindinput="handleImportInput"
    ></textarea>
    <view wx:if="{{importError}}" class="import-error">{{importError}}</view>
    <view class="modal-actions">
      <button class="modal-btn cancel" bindtap="closeImport">取消</button>
      <button class="modal-btn confirm" bindtap="confirmImport">导入</button>
    </view>
  </view>

  <view wx:if="{{exportPanelOpen}}" class="modal-mask" catchtap="closeExportPanel"></view>
  <view wx:if="{{exportPanelOpen}}" class="export-card">
    <view class="modal-head">
      <view class="modal-title">批量导出</view>
      <view class="modal-subtitle">按条件筛选后导出公寓数据</view>
    </view>
    <view class="export-panel-body">
      <view class="export-panel-row">
        <text>区域</text>
        <picker bindchange="onDistrictChange" value="{{exportDistrictIndex}}" range="{{districtOptions}}">
          <view class="filter-picker">{{districtOptions[exportDistrictIndex] || '全部区域'}}</view>
        </picker>
      </view>
    </view>
    <view class="modal-actions">
      <button class="modal-btn cancel" bindtap="closeExportPanel">取消</button>
      <button class="modal-btn confirm" bindtap="exportFiltered" data-type="apartments">导出</button>
    </view>
  </view>

  <view wx:if="{{exportFileOpen}}" class="modal-mask" catchtap="closeExportFileActions"></view>
  <view wx:if="{{exportFileOpen}}" class="export-file-card">
    <view class="export-file-icon">▧</view>
    <view class="modal-title">导出文件已生成</view>
    <text class="export-file-name">{{exportFileName}}</text>
    <text class="export-file-tip">真机微信可在右上角菜单保存或转发</text>
    <button class="export-file-open" bindtap="openExportFile">打开并保存文件</button>
    <button class="export-file-share" bindtap="shareExportFile">转发到微信</button>
    <view class="export-file-cancel" bindtap="closeExportFileActions">取消</view>
  </view>
</view>
