<view class="home-page">
  <view class="slogan-area">
    <view class="slogan-text">晓得了，住得好</view>
    <view class="slogan-sub">帮你找到在郑州的第一个家</view>
  </view>

  <view class="search-area">
    <view class="search-box">
      <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit"></image>
      <input
        class="search-input"
        value="{{searchValue}}"
        placeholder="搜索公寓名称/位置/区域"
        placeholder-class="search-placeholder"
        confirm-type="search"
        bindinput="handleSearchInput"
      />
      <button wx:if="{{searchValue}}" class="search-clear" bindtap="clearSearch">×</button>
    </view>
  </view>

  <view class="quick-entries">
    <view
      wx:for="{{quickEntries}}"
      wx:key="key"
      class="quick-entry qe-{{item.tone}}"
      data-key="{{item.key}}"
      bindtap="handleQuickEntry"
    >
      <view class="quick-entry-icon">
        <image src="{{item.icon}}" mode="aspectFit"></image>
      </view>
      <text class="quick-entry-text">{{item.title}}</text>
    </view>
  </view>

  <view class="filter-shell">
    <view class="filter-bar">
      <button class="filter-btn {{activeFilter === 'district' ? 'active' : ''}}" data-key="district" bindtap="toggleFilter">
        <text>区域</text><text class="filter-arrow">⌄</text>
      </button>
      <button class="filter-btn {{activeFilter === 'price' ? 'active' : ''}}" data-key="price" bindtap="toggleFilter">
        <text>价格</text><text class="filter-arrow">⌄</text>
      </button>
      <button class="filter-btn {{activeFilter === 'room' ? 'active' : ''}}" data-key="room" bindtap="toggleFilter">
        <text>居室</text><text class="filter-arrow">⌄</text>
      </button>
    </view>

    <view wx:if="{{activeFilter}}" class="filter-overlay card">
      <text class="filter-overlay-title">
        {{activeFilter === 'district' ? '选择区域' : activeFilter === 'price' ? '选择价格范围' : '选择居室'}}
      </text>
      <view wx:if="{{activeFilter === 'district'}}" class="filter-options">
        <button
          wx:for="{{districtOptions}}"
          wx:key="*this"
          class="filter-option {{activeDistrict === item ? 'selected' : ''}}"
          data-value="{{item}}"
          bindtap="selectDistrict"
        >{{item}}</button>
      </view>
      <view wx:elif="{{activeFilter === 'price'}}" class="filter-options">
        <button
          wx:for="{{priceOptions}}"
          wx:key="*this"
          class="filter-option {{activePrice === item ? 'selected' : ''}}"
          data-value="{{item}}"
          bindtap="selectPrice"
        >{{item}}</button>
      </view>
      <view wx:else class="filter-options">
        <button
          wx:for="{{roomOptions}}"
          wx:key="*this"
          class="filter-option {{activeRoom === item ? 'selected' : ''}}"
          data-value="{{item}}"
          bindtap="selectRoom"
        >{{item}}</button>
      </view>
    </view>
  </view>

  <view wx:if="{{activeFilter}}" class="filter-backdrop" bindtap="closeFilter"></view>

  <view wx:if="{{filteredApartments.length}}" class="apt-list">
    <view
      wx:for="{{filteredApartments}}"
      wx:key="id"
      class="apt-card"
      data-id="{{item.id}}"
      data-name="{{item.name}}"
      bindtap="handleApartmentTap"
    >
      <view class="apt-card-img {{item.imageClass}}">
        <view class="apt-building low"></view>
        <view class="apt-building high"></view>
        <view class="apt-tag-row">
          <text
            wx:for="{{item.tags}}"
            wx:for-item="tagItem"
            wx:key="label"
            class="tag {{tagItem.className}}"
          >{{tagItem.label}}</text>
        </view>
        <view
          class="apt-fav-mark {{item.favorite ? 'faved' : ''}}"
          catchtap="toggleFavorite"
          data-id="{{item.id}}"
        >♥</view>
      </view>
      <view class="apt-card-body">
        <view class="apt-card-name">{{item.name}}</view>
        <view class="apt-card-price">¥{{item.priceMin}}-{{item.priceMax}}<text class="apt-card-price-unit">/月</text></view>
        <view class="apt-card-location">
          <image src="/assets/icons/location.svg" mode="aspectFit"></image>
          <text>{{item.location}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="apt-empty">
    <view class="empty-mark">⌕</view>
    <text class="empty-title">暂无符合条件的公寓</text>
    <text class="empty-copy">试试放宽筛选条件？</text>
    <button class="reset-link" bindtap="resetFilters">清除筛选</button>
  </view>
</view>
