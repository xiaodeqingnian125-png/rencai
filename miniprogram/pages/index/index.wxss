.home-page {
  min-height: 100vh;
  padding-bottom: 32rpx;
  background: #fafaf6;
}

.slogan-area {
  padding: 32rpx 40rpx 16rpx;
}

.slogan-text {
  color: #2d2318;
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  line-height: 1.2;
}

.slogan-sub {
  margin-top: 6rpx;
  color: #8c7a68;
  font-size: 26rpx;
  line-height: 1.3;
}

.search-area {
  padding: 16rpx 32rpx;
}

.search-box {
  display: flex;
  align-items: center;
  height: 76rpx;
  padding: 0 28rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 24rpx;
  background: #fffdf7;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  color: #2d2318;
  font-size: 30rpx;
}

.search-placeholder {
  color: #a69682;
}

.search-clear {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f0eae0;
  color: #a69682;
  font-size: 34rpx;
  line-height: 1;
}

.quick-entries {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 20rpx 32rpx;
}

.quick-entry {
  display: flex;
  align-items: center;
  min-height: 128rpx;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 24rpx;
  background: #fffdf7;
}

.quick-entry:active {
  transform: scale(0.98);
}

.quick-entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.quick-entry-icon image {
  width: 44rpx;
  height: 44rpx;
}

.quick-entry-text {
  color: #2d2318;
  font-size: 28rpx;
  font-weight: 500;
}

.qe-roommate .quick-entry-icon {
  background: #fff0e7;
}

.qe-community .quick-entry-icon {
  background: #edf5f0;
}

.qe-map .quick-entry-icon {
  background: #edf5fa;
}

.qe-guide .quick-entry-icon {
  background: #f4eef8;
}

.filter-shell {
  position: sticky;
  top: 0;
  z-index: 20;
  background: #fafaf6;
  padding: 16rpx 32rpx;
}

.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.filter-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
  height: 58rpx;
  padding: 0 18rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #2d2318;
  font-size: 26rpx;
  font-weight: 500;
}

.filter-btn.active {
  border-color: #e8723c;
  background: #e8723c;
  color: #ffffff;
}

.filter-arrow {
  font-size: 22rpx;
  line-height: 1;
}

.filter-overlay {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 88rpx;
  z-index: 30;
  padding: 18rpx 24rpx 24rpx;
  box-shadow: 0 24rpx 64rpx rgba(45, 35, 24, 0.1);
}

.filter-overlay-title {
  display: block;
  padding: 8rpx 0 18rpx;
  color: #8c7a68;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  height: 62rpx;
  padding: 0 28rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #5c4a38;
  font-size: 26rpx;
}

.filter-option.selected {
  border-color: #e8723c;
  background: #e8723c;
  color: #ffffff;
}

.filter-backdrop {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10;
  background: rgba(45, 35, 24, 0.08);
}

.apt-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 16rpx 32rpx 40rpx;
}

.apt-card {
  overflow: hidden;
  border: 1rpx solid #f0eae0;
  border-radius: 36rpx;
  background: #fffdf7;
}

.apt-card:active {
  transform: scale(0.99);
}

.apt-card-img {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 386rpx;
}

.apt-img-1 {
  background: linear-gradient(150deg, #f5efe0 0%, #e8dcc8 42%, #dcd0ba 100%);
}

.apt-img-2 {
  background: linear-gradient(150deg, #f0f2eb 0%, #dce3d0 42%, #ced5c2 100%);
}

.apt-img-3 {
  background: linear-gradient(150deg, #f2efeb 0%, #e3dbce 42%, #d4cdc0 100%);
}

.apt-img-4 {
  background: linear-gradient(150deg, #ebf0f3 0%, #d4e0e8 42%, #c4d2db 100%);
}

.apt-img-5 {
  background: linear-gradient(150deg, #f3efe8 0%, #e5dac8 42%, #d6ccbc 100%);
}

.apt-img-6 {
  background: linear-gradient(150deg, #f1f0ea 0%, #e2dfd0 42%, #d3d0c2 100%);
}

.apt-building {
  position: absolute;
  bottom: 0;
  border-radius: 16rpx 16rpx 0 0;
  pointer-events: none;
}

.apt-building.low {
  left: 8%;
  right: 8%;
  height: 62%;
  background: linear-gradient(to top, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0));
}

.apt-building.high {
  left: 25%;
  width: 50%;
  height: 84%;
  background: linear-gradient(to top, rgba(180, 170, 150, 0.54), rgba(200, 190, 170, 0.16), rgba(255, 255, 255, 0));
}

.apt-tag-row {
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  z-index: 2;
  display: flex;
  gap: 12rpx;
}

.apt-tag-row .tag {
  height: 36rpx;
  padding: 0 16rpx;
  background: rgba(255, 253, 247, 0.56);
  border-color: rgba(232, 224, 212, 0.72);
  backdrop-filter: blur(8rpx);
}

.apt-tag-row .tag-hot {
  color: #e8590c;
  border-color: rgba(232, 89, 12, 0.36);
  background: rgba(255, 240, 231, 0.62);
}

.apt-tag-row .tag-subway {
  color: #5b8cb8;
  border-color: rgba(91, 140, 184, 0.36);
  background: rgba(237, 245, 250, 0.62);
}

.apt-tag-row .tag-new {
  color: #e8723c;
  border-color: rgba(232, 114, 60, 0.36);
  background: rgba(255, 240, 231, 0.62);
}

.apt-fav-mark {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(45, 35, 24, 0.28);
  color: #fafaf6;
  font-family: Arial, Helvetica, sans-serif;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
  transform: scaleX(1.08);
}

.apt-fav-mark.faved {
  background: rgba(45, 35, 24, 0.28);
  color: #e04a3a;
  text-shadow: 0 1rpx 0 rgba(255, 253, 247, 0.26);
}

.apt-card-body {
  padding: 28rpx 32rpx 30rpx;
}

.apt-card-name {
  color: #2d2318;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.25;
}

.apt-card-price {
  margin-top: 8rpx;
  color: #e8590c;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.25;
}

.apt-card-price-unit {
  margin-left: 4rpx;
  color: #8c7a68;
  font-size: 26rpx;
  font-weight: 400;
}

.apt-card-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 10rpx;
  color: #8c7a68;
  font-size: 26rpx;
  line-height: 1.45;
}

.apt-card-location image {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.apt-empty {
  padding: 96rpx 40rpx 120rpx;
  text-align: center;
  color: #8c7a68;
}

.empty-mark {
  margin: 0 auto 24rpx;
  color: #e8e0d4;
  font-size: 80rpx;
}

.empty-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
}

.reset-link {
  margin-top: 22rpx;
  color: #e8723c;
  font-size: 28rpx;
  font-weight: 600;
}
