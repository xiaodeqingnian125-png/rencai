.community-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #fafaf6;
}

.community-scroll {
  flex: 1;
  height: 100vh;
}

.qr-section {
  padding: 44rpx 32rpx 28rpx;
}

.qr-card {
  padding: 60rpx 44rpx 42rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 32rpx;
  background: #fffdf7;
  text-align: center;
  box-shadow: 0 12rpx 34rpx rgba(45, 35, 24, 0.045);
}

.qr-code {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto 40rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 24rpx;
  background: #fafaf6;
  overflow: hidden;
  box-shadow: inset 0 0 0 10rpx rgba(255, 253, 247, 0.45);
}

.qr-bg-mark {
  position: absolute;
  right: -42rpx;
  top: -42rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(232, 114, 60, 0.06);
}

.qr-pattern {
  display: flex;
  flex-wrap: wrap;
  width: 320rpx;
  height: 320rpx;
}

.qr-dot {
  width: 4%;
  height: 4%;
  background: #2d2318;
  border-radius: 2rpx;
}

.qr-dot.empty {
  background: transparent;
}

.qr-finder {
  position: absolute;
  z-index: 2;
  width: 72rpx;
  height: 72rpx;
  border: 12rpx solid #2d2318;
  border-radius: 8rpx;
}

.qr-ftl { top: 20rpx; left: 20rpx; }
.qr-ftr { top: 20rpx; right: 20rpx; }
.qr-fbl { bottom: 20rpx; left: 20rpx; }

.qr-icon {
  position: absolute;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border: 12rpx solid #fafaf6;
  border-radius: 16rpx;
  background: #e8723c;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
}

.qr-title {
  color: #2d2318;
  font-size: 40rpx;
  font-weight: 650;
  line-height: 1.25;
}

.qr-sub {
  margin-top: 12rpx;
  color: #8c7a68;
  font-size: 28rpx;
  line-height: 1.45;
}

.qr-hint {
  margin-top: 16rpx;
  color: #e8723c;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
}

.wechat-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 320rpx;
  height: 54rpx;
  margin: 22rpx auto 0;
  padding: 0 18rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 999rpx;
  background: #fafaf6;
  color: #8c7a68;
  font-size: 24rpx;
  font-weight: 600;
}

.wechat-chip text {
  margin-right: 12rpx;
  color: #a69682;
}

.wechat-chip view {
  color: #2d2318;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 0 32rpx 30rpx;
}

.btn-save,
.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  border-radius: 22rpx;
  font-size: 32rpx;
  font-weight: 650;
  transition: opacity 0.16s ease, transform 0.16s ease;
}

.btn-save:active,
.btn-outline:active {
  opacity: 0.86;
  transform: scale(0.99);
}

.btn-save {
  background: #e8723c;
  color: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(232, 114, 60, 0.22);
}

.btn-outline {
  border: 2rpx solid #e8723c;
  color: #e8723c;
}

.btn-symbol {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 20rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.btn-outline .btn-symbol {
  min-width: 56rpx;
  border: 1rpx solid rgba(232, 114, 60, 0.35);
  background: #fff8f2;
}

.benefits {
  padding: 14rpx 32rpx calc(52rpx + env(safe-area-inset-bottom));
}

.benefits-title {
  margin-bottom: 20rpx;
  color: #a69682;
  font-size: 24rpx;
  font-weight: 650;
}

.benefit-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 96rpx;
  border-bottom: 1rpx solid #f0eae0;
}

.benefit-row.last {
  border-bottom: 0;
}

.benefit-check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(91, 154, 111, 0.12);
  color: #5b9a6f;
  font-size: 30rpx;
  font-weight: 700;
}

.benefit-text {
  flex: 1;
  min-width: 0;
  color: #2d2318;
  font-size: 30rpx;
  line-height: 1.4;
}

.benefit-tag {
  color: #8c7a68;
  font-size: 24rpx;
  white-space: nowrap;
}
