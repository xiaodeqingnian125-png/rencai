<view class="edit-page">
  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" enable-back-to-top class="edit-scroll">
    <view class="avatar-section">
      <view class="avatar-wrap">
        <view class="avatar-glow"></view>
        <view class="avatar-circle">{{avatarText}}</view>
      </view>
      <button class="avatar-hint" bindtap="changeAvatar">更换头像</button>
    </view>

    <view class="form-section">
      <view class="form-group">
        <view class="form-row" data-field="nickname" bindtap="openModal">
          <text class="form-label">昵称</text>
          <text class="form-value">{{form.nickname}}</text>
          <image src="/assets/icons/chevron-muted.svg" mode="aspectFit"></image>
        </view>
        <view class="form-row" data-field="phone" bindtap="openModal">
          <text class="form-label">手机号</text>
          <text class="form-value">{{form.phone}}</text>
          <image src="/assets/icons/chevron-muted.svg" mode="aspectFit"></image>
        </view>
      </view>

      <view class="form-group">
        <view class="form-row" bindtap="openApartmentPicker">
          <text class="form-label">公寓</text>
          <text class="form-value">{{form.apartment}}</text>
          <image src="/assets/icons/chevron-muted.svg" mode="aspectFit"></image>
        </view>
        <view class="form-row" data-field="building" bindtap="openModal">
          <text class="form-label">楼栋</text>
          <text class="form-value">{{form.building}}</text>
          <image src="/assets/icons/chevron-muted.svg" mode="aspectFit"></image>
        </view>
      </view>
    </view>

    <view class="status-toggle">
      <view class="status-dot {{form.checkedIn ? 'green' : 'gray'}}"></view>
      <text class="status-label">{{form.checkedIn ? '已入住' : '未入住'}}</text>
      <button class="status-switch {{form.checkedIn ? 'on' : ''}}" bindtap="toggleStatus">
        <view class="switch-knob"></view>
      </button>
    </view>

    <view class="save-section">
      <button class="save-btn" bindtap="saveProfile">保存</button>
    </view>
  </scroll-view>

  <view wx:if="{{modalOpen}}" class="modal-mask" bindtap="closeModal"></view>
  <view wx:if="{{modalOpen}}" class="modal-sheet" catchtap="noop">
    <view class="modal-title">{{modalTitle}}</view>
    <input
      class="modal-input"
      value="{{modalValue}}"
      placeholder="{{modalPlaceholder}}"
      placeholder-class="modal-placeholder"
      confirm-type="done"
      cursor-spacing="24"
      bindinput="handleModalInput"
      bindconfirm="confirmModal"
    />
    <view class="modal-actions">
      <button class="modal-cancel" bindtap="closeModal">取消</button>
      <button class="modal-confirm" bindtap="confirmModal">确定</button>
    </view>
  </view>

  <view wx:if="{{pickerOpen}}" class="picker-mask" bindtap="closePicker"></view>
  <view wx:if="{{pickerOpen}}" class="picker-sheet" catchtap="noop">
    <view class="picker-head">
      <text>选择公寓</text>
      <button bindtap="closePicker">完成</button>
    </view>
    <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="picker-list">
      <view
        wx:for="{{apartmentOptions}}"
        wx:key="*this"
        class="picker-item {{form.apartment === item ? 'selected' : ''}}"
        data-value="{{item}}"
        bindtap="selectApartment"
      >
        <view class="check"><view></view></view>
        <text>{{item}}</text>
      </view>
    </scroll-view>
  </view>
</view>
