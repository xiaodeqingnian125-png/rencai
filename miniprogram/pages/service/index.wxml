<view class="service-page">
  <view class="preview-banner">功能预览 · 即将开放｜当前为示例内容</view>
  <view class="section-hd">
    <text class="section-hd-title">日常活动</text>
    <view class="section-hd-more" bindtap="goActivityList">
      <text>更多</text>
      <image src="/assets/icons/chevron-right.svg" mode="aspectFit"></image>
    </view>
  </view>

  <view class="activity-list">
    <view
      wx:for="{{activities}}"
      wx:key="id"
      class="activity-card"
      data-id="{{item.id}}"
      bindtap="goActivityDetail"
    >
      <view class="activity-cover {{item.coverClass}}">
        <image wx:if="{{item.image}}" class="activity-cover-img" src="{{item.image}}" mode="aspectFill" lazy-load></image>
        <view wx:else class="activity-cover-img grad-cover grad-{{(item.id % 8) + 1}}"></view>
        <view class="activity-cover-shade"></view>
        <text class="activity-badge badge-{{item.typeClass}}">{{item.typeLabel}}</text>
      </view>
      <view class="activity-body">
        <view class="activity-title">{{item.title}}</view>
        <view class="activity-meta">
          <view class="activity-meta-item">
            <image src="/assets/icons/calendar.svg" mode="aspectFit"></image>
            <text>{{item.date}}</text>
          </view>
          <view class="activity-meta-item">
            <image src="/assets/icons/pin.svg" mode="aspectFit"></image>
            <text>{{item.location}}</text>
          </view>
          <view class="activity-meta-item text-only">
            <text>{{item.mode}} · {{item.fee}}</text>
          </view>
        </view>
        <view class="activity-status status-{{item.statusClass}}">{{item.statusText}}</view>
      </view>
    </view>
  </view>

  <view class="launch-btn" bindtap="goActivityPublish">
    <image src="/assets/icons/plus.svg" mode="aspectFit"></image>
    <text>发起活动</text>
  </view>

  <view class="section-divider"></view>

  <view class="section-hd service-hd">
    <text class="section-hd-title">代办服务</text>
    <view class="section-hd-more" bindtap="goServiceList">
      <text>更多</text>
      <image src="/assets/icons/chevron-right.svg" mode="aspectFit"></image>
    </view>
  </view>

  <view class="service-list">
    <view
      wx:for="{{services}}"
      wx:key="id"
      class="service-card"
      data-id="{{item.id}}"
      bindtap="goServiceDetail"
    >
      <view class="service-cover {{item.coverClass}}">
        <image wx:if="{{item.image}}" class="service-cover-img" src="{{item.image}}" mode="aspectFill" lazy-load></image>
        <view wx:else class="service-cover-img grad-cover grad-{{(item.id % 8) + 1}}"></view>
        <view class="service-cover-shade"></view>
        <view class="service-cover-tag">{{item.category}}</view>
      </view>
      <view class="service-body">
        <view class="service-info">
          <view class="service-name">{{item.name}}</view>
          <view class="service-desc">{{item.desc}}</view>
        </view>
        <view class="service-price">¥{{item.price}}<text>{{item.unit}}</text></view>
      </view>
    </view>
  </view>
</view>
