.service-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: #fafaf6;
}

.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx 20rpx;
}

.service-hd {
  padding-top: 34rpx;
}

.section-hd-title {
  color: #2d2318;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-hd-more {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #e8723c;
  font-size: 28rpx;
  font-weight: 500;
}

.section-hd-more image {
  width: 28rpx;
  height: 28rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 32rpx;
}

.activity-card {
  overflow: hidden;
  border: 1rpx solid #f0eae0;
  border-radius: 36rpx;
  background: #fffdf7;
  transition: transform 150ms cubic-bezier(0.28, 0, 0.22, 1);
}

.activity-card:active,
.service-card:active,
.launch-btn:active {
  transform: scale(0.99);
}

.activity-cover {
  position: relative;
  overflow: hidden;
  height: 286rpx;
}

.activity-cover-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.activity-cover-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(45, 35, 24, 0.2) 0%, rgba(45, 35, 24, 0) 36%, rgba(45, 35, 24, 0) 64%, rgba(45, 35, 24, 0.14) 100%);
  pointer-events: none;
}

.cover-grad-1 {
  background: linear-gradient(135deg, #f5e8d8 0%, #e8d4b8 42%, #dcc8a0 100%);
}

.cover-grad-2 {
  background: linear-gradient(135deg, #e8f0e8 0%, #d0e0d0 42%, #bcd0bc 100%);
}

.cover-grad-3 {
  background: linear-gradient(135deg, #f0e8f0 0%, #ddd0e0 42%, #cbc0d0 100%);
}

.cover-orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 253, 247, 0.38);
}

.orb-a {
  width: 220rpx;
  height: 220rpx;
  right: 58rpx;
  top: 36rpx;
}

.orb-b {
  width: 170rpx;
  height: 170rpx;
  left: 56rpx;
  bottom: -42rpx;
}

.activity-badge {
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  height: 42rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.badge-official {
  background: #e8723c;
}

.badge-user {
  background: #5b9a6f;
}

.activity-body {
  padding: 28rpx 32rpx 30rpx;
}

.activity-title {
  color: #2d2318;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.activity-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 30rpx;
  margin-top: 14rpx;
}

.activity-meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
  color: #8c7a68;
  font-size: 26rpx;
  line-height: 1.35;
}

.activity-meta-item image {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.text-only {
  color: #8c7a68;
}

.activity-status {
  margin-top: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.status-open {
  color: #5b9a6f;
}

.status-full {
  color: #8c7a68;
}

.launch-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 92rpx;
  margin: 24rpx 32rpx 0;
  border: 3rpx dashed #e8e0d4;
  border-radius: 24rpx;
  color: #e8723c;
  font-size: 30rpx;
  font-weight: 500;
}

.launch-btn image {
  width: 36rpx;
  height: 36rpx;
}

.section-divider {
  height: 12rpx;
  margin-top: 40rpx;
  border-top: 1rpx solid #f0eae0;
  border-bottom: 1rpx solid #f0eae0;
  background: #fffdf7;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 32rpx;
}

.service-card {
  overflow: hidden;
  border: 1rpx solid #f0eae0;
  border-radius: 24rpx;
  background: #fffdf7;
  transition: transform 150ms cubic-bezier(0.28, 0, 0.22, 1);
}

.service-cover {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 286rpx;
}

.service-cover-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.service-cover-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(45, 35, 24, 0.2) 0%, rgba(45, 35, 24, 0) 36%, rgba(45, 35, 24, 0) 64%, rgba(45, 35, 24, 0.14) 100%);
  pointer-events: none;
}

.service-cover-tag {
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  height: 40rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.82);
  color: #5c4a38;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 40rpx;
}

.service-body {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
}

.service-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  background: #fff0e7;
  flex-shrink: 0;
}

.service-icon image {
  width: 48rpx;
  height: 48rpx;
}

.service-info {
  flex: 1;
  min-width: 0;
}

.service-name {
  color: #2d2318;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.service-desc {
  overflow: hidden;
  margin-top: 6rpx;
  color: #8c7a68;
  font-size: 26rpx;
  line-height: 1.4;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-price {
  flex-shrink: 0;
  color: #e8590c;
  font-size: 36rpx;
  font-weight: 600;
}

.service-price text {
  margin-left: 2rpx;
  color: #8c7a68;
  font-size: 24rpx;
  font-weight: 400;
}
