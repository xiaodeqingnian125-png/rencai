.detail-page {
  position: relative;
  height: 100vh;
  overflow: hidden;
  background: #fafaf6;
  color: #2d2318;
}

.detail-hero {
  position: relative;
  overflow: hidden;
  height: 480rpx;
  padding-top: env(safe-area-inset-top);
  flex-shrink: 0;
}

.hero-zd {
  background: linear-gradient(150deg, #f5efe0 0%, #e8dcc8 50%, #dcd0ba 100%);
}

.hero-gx {
  background: linear-gradient(150deg, #f0f2eb 0%, #dce3d0 50%, #ced5c2 100%);
}

.hero-jk {
  background: linear-gradient(150deg, #f2efeb 0%, #e3dbce 50%, #d4cdc0 100%);
}

.hero-gq {
  background: linear-gradient(150deg, #ebf0f3 0%, #d4e0e8 50%, #c4d2db 100%);
}

.hero-eq {
  background: linear-gradient(150deg, #f3efe8 0%, #e5dac8 50%, #d6ccbc 100%);
}

.hero-zy {
  background: linear-gradient(150deg, #f1f0ea 0%, #e2dfd0 50%, #d3d0c2 100%);
}

.hero-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.hero-cover-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(45, 35, 24, 0.24) 0%, rgba(45, 35, 24, 0) 32%, rgba(45, 35, 24, 0) 60%, rgba(45, 35, 24, 0.18) 100%);
  pointer-events: none;
}

.hero-btn {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 22rpx);
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.25);
  color: #ffffff;
  font-size: 52rpx;
  font-weight: 600;
  line-height: 1;
}

.hero-btn::after {
  display: none;
}

.hero-btn image {
  width: 36rpx;
  height: 36rpx;
}

.back-btn {
  left: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  color: #2d2318;
}

.bottom-fav.on {
  color: #e04a3a;
}

.hero-building {
  position: absolute;
  bottom: 0;
  border-radius: 32rpx 32rpx 0 0;
}

.hero-building.low {
  left: 8%;
  right: 8%;
  height: 62%;
  background: linear-gradient(to top, rgba(255, 253, 247, 0.76), rgba(255, 253, 247, 0.18), rgba(255, 253, 247, 0));
}

.hero-building.high {
  left: 25%;
  width: 50%;
  height: 84%;
  background: linear-gradient(to top, rgba(180, 170, 150, 0.54), rgba(200, 190, 170, 0.16), rgba(255, 253, 247, 0));
}

.hero-dots {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 28rpx;
  z-index: 3;
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.hero-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.55);
}

.hero-dot.active {
  width: 36rpx;
  background: #fafaf6;
}

.detail-scroll {
  height: calc(100vh - 480rpx);
}

.price-hero {
  padding: 32rpx 32rpx 8rpx;
}

.detail-apt-name {
  color: #2d2318;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
}

.price-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  margin-top: 8rpx;
}

.price-value {
  color: #e8590c;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.1;
}

.price-unit {
  margin-bottom: 8rpx;
  color: #8c7a68;
  font-size: 28rpx;
}

.location-section {
  padding: 16rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0eae0;
}

.favorite-chips {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.fav-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  height: 52rpx;
  padding: 0 20rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #5c4a38;
  font-size: 24rpx;
  line-height: 1;
}

.fav-chip image {
  width: 24rpx;
  height: 24rpx;
}

.fav-num {
  color: #2d2318;
  font-weight: 700;
  font-size: 26rpx;
  margin-right: 2rpx;
}

.location-tap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 16rpx;
  background: #fffdf7;
  transition: transform 150ms cubic-bezier(0.28, 0, 0.22, 1);
}

.location-tap-hover {
  transform: scale(0.99);
  background: #f0eae0;
}

.location-tap > image {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.location-tap-text {
  flex: 1;
  min-width: 0;
}

.location-tap-addr {
  color: #2d2318;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
}

.location-tap-meta {
  display: block;
  margin-top: 4rpx;
  color: #5b9a6f;
  font-size: 24rpx;
  line-height: 1.35;
}

.location-tap-arrow {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
  color: #e8723c;
  font-size: 24rpx;
  font-weight: 600;
}

.location-tap-arrow image {
  width: 24rpx;
  height: 24rpx;
}

.info-section,
.room-section,
.comment-section {
  padding: 32rpx;
  border-bottom: 1rpx solid #f0eae0;
}

.info-title {
  margin-bottom: 20rpx;
  color: #2d2318;
  font-size: 34rpx;
  font-weight: 650;
  line-height: 1.25;
}

.cost-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.cost-cell {
  min-width: 0;
  padding: 22rpx 12rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 16rpx;
  background: #fffdf7;
  text-align: center;
}

.cost-cell.inactive {
  background: transparent;
  color: #a69682;
}

.cost-label {
  color: #8c7a68;
  font-size: 24rpx;
}

.cost-value {
  overflow: hidden;
  margin-top: 8rpx;
  color: #2d2318;
  font-size: 26rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.inactive .cost-value {
  color: #a69682;
}

.fac-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 28rpx 12rpx;
  text-align: center;
}

.fac-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: #5c4a38;
  font-size: 26rpx;
}

.fac-cell.inactive {
  color: #a69682;
}

.fac-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border: 1rpx solid rgba(232, 114, 60, 0.28);
  border-radius: 18rpx;
  color: #e8723c;
  background: #fff8f2;
  font-size: 24rpx;
  font-weight: 700;
}

.inactive .fac-icon {
  border-color: #e8e0d4;
  color: #c4b7a8;
  background: transparent;
}

.nearby-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.nearby-tag {
  height: 64rpx;
  padding: 0 24rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 16rpx;
  background: #fffdf7;
  color: #5c4a38;
  font-size: 26rpx;
  line-height: 64rpx;
}

.room-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.room-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 24rpx;
  background: #fffdf7;
  transition: transform 150ms cubic-bezier(0.28, 0, 0.22, 1);
}

.room-card:active {
  transform: scale(0.99);
}

.room-img {
  position: relative;
  overflow: hidden;
  width: 160rpx;
  height: 128rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.room-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.ri-1 {
  background: linear-gradient(135deg, #efe8d8, #e0d4b8);
}

.ri-2 {
  background: linear-gradient(135deg, #e8efe8, #d0e0d0);
}

.ri-3 {
  background: linear-gradient(135deg, #efe8f0, #ddd0e0);
}

.room-plan-line {
  position: absolute;
  background: rgba(255, 253, 247, 0.72);
  border-radius: 999rpx;
}

.room-plan-line.a {
  left: 28rpx;
  right: 28rpx;
  top: 46rpx;
  height: 8rpx;
}

.room-plan-line.b {
  top: 26rpx;
  bottom: 26rpx;
  left: 72rpx;
  width: 8rpx;
}

.room-info {
  flex: 1;
  min-width: 0;
}

.room-name {
  overflow: hidden;
  color: #2d2318;
  font-size: 30rpx;
  font-weight: 650;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-meta {
  margin-top: 6rpx;
  color: #8c7a68;
  font-size: 24rpx;
  line-height: 1.35;
}

.room-price {
  color: #e8590c;
  font-size: 32rpx;
  font-weight: 650;
  white-space: nowrap;
}

.room-price text {
  color: #8c7a68;
  font-size: 24rpx;
  font-weight: 400;
}

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.comment-header .info-title {
  margin-bottom: 0;
}

.write-btn {
  height: 64rpx;
  padding: 0 28rpx;
  border: 1rpx solid #e8723c;
  border-radius: 999rpx;
  color: #e8723c;
  font-size: 26rpx;
  font-weight: 600;
}

.comment-list {
  margin-top: 12rpx;
}

.comment-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0eae0;
}

.comment-item:last-child {
  border-bottom: 0;
}

.comment-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.comment-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.ca-1 {
  background: linear-gradient(135deg, #e8a0b0, #d08090);
}

.ca-2 {
  background: linear-gradient(135deg, #8cb0c8, #6c90a8);
}

.ca-3 {
  background: linear-gradient(135deg, #a0c8a0, #80b080);
}

.comment-name {
  color: #2d2318;
  font-size: 28rpx;
  font-weight: 650;
}

.comment-time {
  margin-left: auto;
  color: #8c7a68;
  font-size: 24rpx;
}

.comment-body {
  color: #5c4a38;
  font-size: 28rpx;
  line-height: 1.55;
}

.comment-actions {
  display: flex;
  gap: 32rpx;
  margin-top: 14rpx;
}

.comment-actions button {
  color: #8c7a68;
  font-size: 24rpx;
}

.scroll-spacer {
  height: 128rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0eae0;
  background: rgba(250, 250, 246, 0.94);
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-width: 0;
  height: 88rpx;
  border-radius: 24rpx;
  background: #e8723c;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 650;
}

.bottom-fav {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  padding: 0;
  border: 1rpx solid #e8e0d4;
  border-radius: 24rpx;
  background: #fffdf7;
  color: #a69682;
  line-height: 1;
}

.bottom-fav::after {
  display: none;
}

.bottom-fav image {
  width: 40rpx;
  height: 40rpx;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  background: rgba(45, 35, 24, 0.32);
  animation: overlay-fade-in 150ms cubic-bezier(0.28, 0, 0.22, 1) both;
}

.comment-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  padding: 20rpx 36rpx calc(36rpx + env(safe-area-inset-bottom));
  border-radius: 48rpx 48rpx 0 0;
  background: #fafaf6;
  box-shadow: 0 -28rpx 72rpx rgba(45, 35, 24, 0.18);
  animation: sheet-slide-up 220ms cubic-bezier(0.28, 0, 0.22, 1) both;
}

.sheet-grabber {
  width: 84rpx;
  height: 8rpx;
  margin: 0 auto 28rpx;
  border-radius: 999rpx;
  background: #e8e0d4;
}

.sheet-title {
  color: #2d2318;
  font-size: 36rpx;
  font-weight: 700;
}

.sheet-subtitle {
  margin-top: 8rpx;
  color: #8c7a68;
  font-size: 26rpx;
  line-height: 1.45;
}

.comment-textarea {
  width: 100%;
  min-height: 192rpx;
  margin-top: 28rpx;
  padding: 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 24rpx;
  background: #fffdf7;
  color: #2d2318;
  font-size: 28rpx;
  line-height: 1.5;
}

.comment-rule {
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
  color: #8c7a68;
  font-size: 24rpx;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.cancel-btn,
.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-width: 0;
  height: 84rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 650;
}

.cancel-btn {
  background: #fffdf7;
  color: #5c4a38;
}

.submit-btn {
  background: #e8723c;
  color: #ffffff;
}

/* 管理员封面图管理区域 */
.admin-image-section {
  margin: 24rpx 24rpx 0;
  padding: 28rpx 24rpx;
  background: #fffdf7;
  border-radius: 24rpx;
  border: 1rpx dashed #e8723c;
}

.admin-section-title {
  font-size: 28rpx;
  font-weight: 650;
  color: #e8723c;
  margin-bottom: 20rpx;
}

/* 管理员经纬度修正区域 */
.admin-location-section {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0eae0;
}

.location-display {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #8c7a68;
  margin-bottom: 16rpx;
}

.location-map {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  border: 1rpx solid #f0eae0;
}

.location-tip {
  text-align: center;
  font-size: 22rpx;
  color: #a69682;
  margin-top: 12rpx;
}
