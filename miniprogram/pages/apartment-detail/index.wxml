<view wx:if="{{loading}}" class="state-empty">
  <text class="empty-mark">⏳</text>
  <text class="empty-title">正在加载公寓详情...</text>
  <text class="empty-copy">请稍候</text>
</view>

<view wx:elif="{{notFound}}" class="state-empty">
  <text class="empty-mark">⌕</text>
  <text class="empty-title">公寓不存在</text>
  <text class="empty-copy">该公寓可能已下架</text>
  <button class="reset-link" bindtap="goBack">返回首页</button>
</view>

<view wx:elif="{{error}}" class="state-empty">
  <text class="empty-mark">⚠️</text>
  <text class="empty-title">{{error}}</text>
  <text class="empty-copy">请检查网络或稍后重试</text>
  <button class="reset-link" bindtap="retryLoad">重新加载</button>
</view>

<view wx:if="{{apartment}}" class="detail-page">
  <view class="detail-hero {{apartment.heroClass}}">
    <image wx:if="{{apartment.image}}" class="hero-cover" src="{{apartment.image}}" mode="aspectFill"></image>
    <view wx:else class="hero-cover grad-cover grad-{{(apartment.id % 6) + 1}}"></view>
    <view class="hero-cover-shade"></view>
    <button
      class="hero-btn back-btn"
      style="top: {{navTop}}; width: {{navWidth}}; height: {{navHeight}}; line-height: {{navHeight}}; border-radius: {{navRadius}};"
      bindtap="goBack">
      <image src="/assets/icons/nav-back-dark.svg" mode="aspectFit" style="width: {{navIconSize}}; height: {{navIconSize}};"></image>
    </button>
    <view class="hero-dots">
      <view class="hero-dot active"></view>
      <view class="hero-dot"></view>
      <view class="hero-dot"></view>
    </view>
  </view>

  <scroll-view class="detail-scroll" scroll-y>
    <view class="price-hero">
      <view class="detail-apt-name">{{apartment.name}}</view>
      <view class="price-row">
        <text class="price-value">{{apartment.priceText}}</text>
        <text class="price-unit">/月</text>
      </view>
    </view>

    <view class="location-section">
      <view class="favorite-chips">
        <view class="fav-chip fav-chip-apt">
          <image src="/assets/icons/heart-filled.svg" mode="aspectFit"></image>
          <text><text class="fav-num">{{apartment.apartmentFavoriteCount}}</text>人收藏公寓</text>
        </view>
        <view class="fav-chip fav-chip-room">
          <image src="/assets/icons/location-accent.svg" mode="aspectFit"></image>
          <text><text class="fav-num">{{apartment.roomFavoriteCount}}</text>人收藏户型</text>
        </view>
      </view>
      <view class="location-tap" bindtap="goMap" hover-class="location-tap-hover">
        <image src="/assets/icons/location-accent.svg" mode="aspectFit"></image>
        <view class="location-tap-text">
          <view class="location-tap-addr">{{apartment.location}}</view>
          <text class="location-tap-meta">{{apartment.locationMeta}}</text>
        </view>
        <view class="location-tap-arrow">
          <text>地图</text>
          <image src="/assets/icons/chevron-right.svg" mode="aspectFit"></image>
        </view>
      </view>
    </view>

    <view class="info-section">
      <view class="info-title">费用信息</view>
      <view class="cost-grid">
        <view wx:for="{{apartment.costs}}" wx:key="label" class="cost-cell {{item.active ? 'active' : 'inactive'}}">
          <text class="cost-label">{{item.label}}</text>
          <view class="cost-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view class="info-section">
      <view class="info-title">配套设施</view>
      <view class="fac-grid">
        <view wx:for="{{apartment.privateFacilities}}" wx:key="label" class="fac-cell {{item.active ? 'active' : 'inactive'}}">
          <view class="fac-icon">{{item.icon}}</view>
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="info-section">
      <view class="info-title">公共设施</view>
      <view class="fac-grid">
        <view wx:for="{{apartment.publicFacilities}}" wx:key="label" class="fac-cell {{item.active ? 'active' : 'inactive'}}">
          <view class="fac-icon">{{item.icon}}</view>
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="info-section">
      <view class="info-title">周边服务</view>
      <view class="fac-grid nearby-grid">
        <view wx:for="{{apartment.nearby}}" wx:key="label" class="fac-cell nearby-cell {{item.active ? 'active' : 'inactive'}}">
          <view class="fac-icon">{{item.icon}}</view>
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{visibleFloorPlans.length}}" class="floor-plan-section">
      <view class="floor-plan-header">
        <view class="info-title">公寓平面图</view>
        <view wx:if="{{hasMoreFloorPlans}}" class="floor-plan-more" bindtap="goMoreFloorPlans">更多</view>
      </view>
      <view class="floor-plan-list">
        <view wx:for="{{visibleFloorPlans}}" wx:key="image" class="floor-plan-item">
          <image
            class="floor-plan-image"
            src="{{item.image}}"
            mode="widthFix"
            lazy-load
            data-index="{{index}}"
            bindtap="previewFloorPlan"
          ></image>
          <view class="floor-plan-caption">{{item.name}}</view>
        </view>
      </view>
    </view>

    <view class="room-section">
      <view class="info-title">户型选择</view>
      <view class="room-list">
        <view
          wx:for="{{apartment.rooms}}"
          wx:key="id"
          class="room-card"
          data-apt-id="{{apartment.id}}"
          data-room-id="{{item.id}}"
          data-apartment-code="{{item.apartment_code}}"
          bindtap="goRoomDetail"
        >
          <view class="room-img {{item.imageClass}}">
            <image wx:if="{{item.image}}" class="room-cover" src="{{item.image}}" mode="aspectFill" lazy-load></image>
            <view wx:else class="room-cover grad-cover grad-{{(item.id % 6) + 1}}"></view>
          </view>
          <view class="room-info">
            <view class="room-name">{{item.name}}</view>
            <view class="room-meta">{{item.area}} · {{item.orient}} · {{item.layout}}</view>
          </view>
          <view class="room-price">{{item.price}}<text>/月起</text></view>
        </view>
      </view>
    </view>

    <view class="comment-section">
      <view class="comment-header">
        <view class="info-title">住户评价</view>
        <button class="write-btn" bindtap="openCommentSheet">写评价</button>
      </view>
      <view class="comment-list">
        <view wx:for="{{apartment.comments}}" wx:key="body" class="comment-item">
          <view class="comment-user">
            <view class="comment-avatar {{item.avatarClass}}">{{item.avatar}}</view>
            <text class="comment-name">{{item.name}}</text>
            <text class="comment-time">{{item.time}}</text>
          </view>
          <view class="comment-body">{{item.body}}</view>
          <view class="comment-actions">
            <button data-index="{{index}}" bindtap="likeComment">赞 {{item.likes}}</button>
          </view>
        </view>
      </view>
    </view>

    <view class="scroll-spacer"></view>
  </scroll-view>

  <view class="bottom-bar">
    <button class="share-btn" open-type="share">分享给朋友</button>
    <button class="bottom-fav {{favorite ? 'on' : ''}}" bindtap="toggleFavorite">
      <image wx:if="{{favorite}}" src="/assets/icons/heart-filled.svg" mode="aspectFit"></image>
      <image wx:else src="/assets/icons/heart-outline-dark.svg" mode="aspectFit"></image>
    </button>
  </view>

  <view wx:if="{{commentSheetOpen}}" class="sheet-mask" catchtap="closeCommentSheet"></view>
  <view wx:if="{{commentSheetOpen}}" class="comment-sheet">
    <view class="sheet-grabber"></view>
    <view class="sheet-title">写住户评价</view>
    <view class="sheet-subtitle">仅支持纯文字评价，200 字以内；5 分钟内不可重复提交。</view>
    <textarea
      class="comment-textarea"
      maxlength="200"
      value="{{commentDraft}}"
      placeholder="例如：住了三个月，通勤、物业、周边生活都是什么感受？"
      bindinput="handleCommentInput"
    ></textarea>
    <view class="comment-rule">
      <text>纯文字评价</text>
      <text>{{commentCount}}</text>
    </view>
    <view class="sheet-actions">
      <button class="cancel-btn" bindtap="closeCommentSheet">取消</button>
      <button class="submit-btn" bindtap="submitComment">发布评价</button>
    </view>
  </view>
</view>

<login-modal
  visible="{{loginModalVisible}}"
  bind:loginsuccess="onLoginSuccess"
  bind:cancel="onLoginCancel"
></login-modal>
