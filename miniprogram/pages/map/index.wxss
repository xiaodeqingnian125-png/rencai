.map-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: #fafaf6;
}

.map-area {
  position: relative;
  flex: 1;
  min-height: 0;
  overflow: hidden;
  background: #dfe7df;
}

.tencent-map {
  width: 100%;
  height: 100%;
}

.map-topbar {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 24rpx;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 253, 247, 0.96);
  box-sizing: border-box;
}

.map-title-group {
  flex: 1;
  min-width: 0;
}

.map-kicker {
  color: #8c7a68;
  font-size: 22rpx;
  line-height: 30rpx;
}

.map-title {
  margin-top: 4rpx;
  color: #2d2318;
  font-size: 34rpx;
  font-weight: 650;
  line-height: 42rpx;
}

.map-count {
  flex-shrink: 0;
  margin-left: 20rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fef8ef;
  color: #e8590c;
  font-size: 22rpx;
  font-weight: 650;
  line-height: 30rpx;
}

.locate-btn {
  position: absolute;
  right: 28rpx;
  bottom: 232rpx;
  z-index: 12;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #fffdf7;
  box-sizing: border-box;
}

.locate-btn.locating {
  opacity: 0.72;
}

.locate-icon {
  position: relative;
  width: 38rpx;
  height: 38rpx;
  border: 4rpx solid #e8723c;
  border-radius: 50%;
  box-sizing: border-box;
}

.locate-line {
  position: absolute;
  background: #e8723c;
}

.locate-line-v {
  left: 50%;
  top: -11rpx;
  bottom: -11rpx;
  width: 4rpx;
  transform: translateX(-50%);
}

.locate-line-h {
  top: 50%;
  left: -11rpx;
  right: -11rpx;
  height: 4rpx;
  transform: translateY(-50%);
}

.locate-core {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 1;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #e8723c;
  transform: translate(-50%, -50%);
}

.map-info-card {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 26rpx;
  z-index: 11;
  display: flex;
  align-items: center;
  min-height: 154rpx;
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  background: #fffdf7;
  box-sizing: border-box;
}

.map-info-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 18rpx;
  background: #2d2318;
  color: #fffdf7;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 84rpx;
  text-align: center;
  flex-shrink: 0;
}

.map-info-body {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.map-info-head {
  display: flex;
  align-items: baseline;
  min-width: 0;
}

.map-info-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #2d2318;
  font-size: 30rpx;
  font-weight: 650;
  line-height: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-info-price {
  flex-shrink: 0;
  margin-left: 12rpx;
  color: #e8590c;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 32rpx;
  white-space: nowrap;
}

.map-info-location {
  overflow: hidden;
  margin-top: 6rpx;
  color: #8c7a68;
  font-size: 23rpx;
  line-height: 31rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-info-meta {
  overflow: hidden;
  margin-top: 3rpx;
  color: #a69682;
  font-size: 21rpx;
  line-height: 29rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-info-actions {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.map-info-route,
.map-info-detail {
  width: 72rpx;
  height: 52rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 52rpx;
  text-align: center;
}

.map-info-route {
  background: #2d2318;
  color: #fffdf7;
}

.map-info-detail {
  margin-top: 12rpx;
  background: #fef8ef;
  color: #e8590c;
}

.apt-strip {
  max-height: 304rpx;
  padding: 16rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0eae0;
  background: #fffdf7;
  flex-shrink: 0;
  box-sizing: border-box;
}

.apt-strip-item {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 12rpx 10rpx;
  border-bottom: 1rpx solid #f0eae0;
  border-radius: 14rpx;
  box-sizing: border-box;
  transition: background 160ms ease;
}

.apt-strip-item.active {
  background: #fef8ef;
}

.apt-strip-item.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 6rpx;
  background: #e8723c;
}

.apt-strip-item-hover {
  background: #faf4ea;
}

.apt-strip-item:last-child {
  border-bottom: 0;
}

.apt-strip-dot {
  width: 18rpx;
  height: 18rpx;
  margin: 0 20rpx 0 10rpx;
  border-radius: 50%;
  background: #5b8cb8;
  flex-shrink: 0;
}

.apt-strip-dot.active {
  background: #e8723c;
}

.apt-strip-info {
  flex: 1;
  min-width: 0;
}

.apt-strip-name {
  overflow: hidden;
  color: #2d2318;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 36rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.apt-strip-detail {
  overflow: hidden;
  margin-top: 5rpx;
  color: #8c7a68;
  font-size: 24rpx;
  line-height: 32rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.apt-strip-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: 18rpx;
}

.apt-strip-price {
  color: #e8590c;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 32rpx;
  white-space: nowrap;
}

.apt-strip-detail-btn {
  width: 76rpx;
  height: 42rpx;
  margin: 8rpx 0 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  background: #f4ecdf;
  color: #5c4a38;
  font-size: 22rpx;
  font-weight: 650;
  line-height: 42rpx;
}

.apt-strip-detail-btn::after {
  display: none;
}
