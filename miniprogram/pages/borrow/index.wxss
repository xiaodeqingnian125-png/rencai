.borrow-page {
  position: relative;
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: #fafaf6;
}

.borrow-search-area {
  padding: 16rpx 32rpx;
}

.borrow-search-box {
  display: flex;
  align-items: center;
  height: 76rpx;
  padding: 0 28rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 24rpx;
  background: #fffdf7;
}

.borrow-search-box image {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.borrow-search-box input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  color: #2d2318;
  font-size: 30rpx;
}

.borrow-placeholder {
  color: #a69682;
}

.cat-scroll {
  width: 100%;
  white-space: nowrap;
}

.cat-row {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 32rpx;
}

.cat-chip {
  flex-shrink: 0;
  height: 58rpx;
  padding: 0 28rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  background: transparent;
  color: #2d2318;
  font-size: 26rpx;
  font-weight: 500;
}

.cat-chip.active {
  border-color: #e8723c;
  background: #e8723c;
  color: #ffffff;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 8rpx 32rpx 36rpx;
}

.item-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 168rpx;
  padding: 24rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 36rpx;
  background: #fffdf7;
}

.item-card:active,
.float-pub:active {
  transform: scale(0.99);
}

.item-thumb {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 144rpx;
  height: 144rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.item-thumb image {
  width: 58rpx;
  height: 58rpx;
  opacity: 0.48;
}

.thumb-tool {
  background: linear-gradient(135deg, #efe8d8, #e0d4b8);
}

.thumb-outdoor {
  background: linear-gradient(135deg, #e8efe8, #d0e0d0);
}

.thumb-appliance {
  background: linear-gradient(135deg, #efe8f0, #ddd0e0);
}

.thumb-other {
  background: linear-gradient(135deg, #f0ece2, #e0d8c8);
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  color: #2d2318;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.3;
}

.item-desc {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 8rpx;
  color: #8c7a68;
  font-size: 26rpx;
  line-height: 1.4;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.item-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 10rpx;
  color: #a69682;
  font-size: 24rpx;
  line-height: 1.4;
}

.item-tag {
  height: 34rpx;
  padding: 0 16rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 999rpx;
  color: #8c7a68;
  font-size: 22rpx;
  line-height: 34rpx;
}

.item-status {
  align-self: center;
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.status-available {
  color: #5b9a6f;
}

.status-borrowed {
  color: #8c7a68;
}

.status-pending {
  color: #e8590c;
}

.status-returned {
  color: #5b8cb8;
}

.float-pub {
  position: fixed;
  right: 32rpx;
  bottom: 148rpx;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #e8723c;
  box-shadow: 0 12rpx 40rpx rgba(232, 114, 60, 0.35);
}

.float-pub image {
  width: 46rpx;
  height: 46rpx;
  filter: brightness(0) invert(1);
}

.borrow-empty {
  padding: 120rpx 40rpx;
  text-align: center;
  color: #8c7a68;
}

.empty-mark {
  margin-bottom: 22rpx;
  color: #e8e0d4;
  font-size: 78rpx;
}

.empty-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
}
