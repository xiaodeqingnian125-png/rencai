<view wx:if="{{service}}" class="detail-page">
  <view class="service-hero {{service.coverClass}}">
    <image wx:if="{{service.image}}" class="service-hero-img" src="{{service.image}}" mode="aspectFill"></image>
    <view wx:else class="service-hero-img grad-cover grad-{{(service.id % 8) + 1}}"></view>
    <view class="service-hero-shade"></view>
  </view>

  <view class="content">
    <view class="title-row">
      <view>
        <view class="service-title">{{service.name}}</view>
        <view class="service-sub">{{service.category}} · {{service.duration}}</view>
      </view>
      <view class="service-price">¥{{service.price}}<text>{{service.unit}}</text></view>
    </view>

    <view class="notice-card">
      <text>支付降级方案</text>
      <view>微信支付商户号未配置前，本服务仅提交需求，由客服线下联系确认。</view>
    </view>

    <view class="section-card">
      <view class="section-title">服务说明</view>
      <view class="paragraph">{{service.detail}}</view>
    </view>

    <view class="section-card">
      <view class="section-title">服务范围</view>
      <view class="paragraph">{{service.scope}}</view>
    </view>

    <view class="section-card">
      <view class="section-title">处理流程</view>
      <view wx:for="{{service.steps}}" wx:key="*this" class="step-row">
        <view class="step-index">{{index + 1}}</view>
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="order-btn" bindtap="openOrder">提交需求</button>
  </view>

  <view wx:if="{{orderOpen}}" class="sheet-mask" catchtap="closeOrder"></view>
  <view wx:if="{{orderOpen}}" class="form-sheet">
    <view class="sheet-handle"></view>
    <view class="sheet-title">填写服务需求</view>
    <view class="field">
      <text>联系人</text>
      <input placeholder="请输入姓名" data-field="name" bindinput="handleInput" />
    </view>
    <view class="field">
      <text>手机号</text>
      <input type="number" maxlength="11" placeholder="用于客服联系" data-field="phone" bindinput="handleInput" />
    </view>
    <view class="field">
      <text>服务地址</text>
      <input placeholder="如：郑东人才公寓 3-1202" data-field="address" bindinput="handleInput" />
    </view>
    <view class="field">
      <text>备注</text>
      <textarea placeholder="补充时间、取件码或材料说明" data-field="remark" bindinput="handleInput"></textarea>
    </view>
    <button class="submit-btn" bindtap="submitOrder">提交给客服</button>
  </view>
</view>

<login-modal
  visible="{{loginModalVisible}}"
  bind:loginsuccess="onLoginSuccess"
  bind:cancel="onLoginCancel"
></login-modal>
