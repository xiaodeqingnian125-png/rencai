.detail-page {
  min-height: 100vh;
  padding-bottom: 150rpx;
  background: #fafaf6;
}

.service-hero {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 330rpx;
}

.service-hero image {
  width: 116rpx;
  height: 116rpx;
  opacity: 0.42;
}

.service-cover-1 {
  background: #fff0e7;
}

.service-cover-2 {
  background: #e8f0e8;
}

.service-cover-3 {
  background: #edf5fa;
}

.service-cover-4 {
  background: #f4edf7;
}

.content {
  padding: 34rpx 32rpx 30rpx;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.service-title {
  color: #2d2318;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
}

.service-sub {
  margin-top: 8rpx;
  color: #8c7a68;
  font-size: 26rpx;
}

.service-price {
  flex-shrink: 0;
  color: #e8590c;
  font-size: 42rpx;
  font-weight: 800;
}

.service-price text {
  margin-left: 2rpx;
  color: #8c7a68;
  font-size: 22rpx;
  font-weight: 400;
}

.notice-card,
.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 28rpx;
  background: #fffdf7;
}

.notice-card {
  background: #fff8f2;
}

.notice-card text,
.section-title {
  display: block;
  margin-bottom: 12rpx;
  color: #2d2318;
  font-size: 32rpx;
  font-weight: 700;
}

.notice-card view,
.paragraph {
  color: #5c4a38;
  font-size: 29rpx;
  line-height: 1.6;
}

.step-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
  color: #5c4a38;
  font-size: 28rpx;
}

.step-index {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #e8723c;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0eae0;
  background: #fffdf7;
}

.order-btn,
.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: #e8723c;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 750;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  background: rgba(45, 35, 24, 0.32);
}

.form-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  max-height: 78vh;
  overflow-y: auto;
  padding: 18rpx 36rpx calc(36rpx + env(safe-area-inset-bottom));
  border-radius: 48rpx 48rpx 0 0;
  background: #fffdf7;
}

.sheet-handle {
  width: 84rpx;
  height: 10rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #e8e0d4;
}

.sheet-title {
  margin-bottom: 22rpx;
  color: #2d2318;
  font-size: 36rpx;
  font-weight: 750;
}

.field {
  margin-bottom: 20rpx;
}

.field text {
  display: block;
  margin-bottom: 10rpx;
  color: #8c7a68;
  font-size: 26rpx;
}

.field input,
.field textarea {
  width: 100%;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 20rpx;
  background: #fafaf6;
  color: #2d2318;
  font-size: 30rpx;
}

.field input {
  height: 84rpx;
}

.field textarea {
  height: 160rpx;
  padding-top: 22rpx;
  line-height: 1.5;
}
