.roommate-page {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #fafaf6;
}

.type-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  padding: 16rpx 32rpx 12rpx;
  flex-shrink: 0;
}

.type-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  background: transparent;
  color: #2d2318;
  font-size: 28rpx;
  font-weight: 650;
  white-space: nowrap;
  transition: transform 0.16s ease, background 0.16s ease, color 0.16s ease;
}

.type-tab:active {
  transform: scale(0.96);
}

.type-tab.active {
  border-color: #e8723c;
  background: #e8723c;
  color: #ffffff;
}

.chip-count {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #fef8ef;
  color: #a69682;
  font-size: 20rpx;
  line-height: 32rpx;
}

.type-tab.active .chip-count {
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
}

.sub-filter-row {
  display: flex;
  gap: 12rpx;
  padding: 4rpx 32rpx 14rpx;
  flex-shrink: 0;
}

.sub-filter-btn {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 0;
  min-width: 0;
  height: 58rpx;
  padding: 0 14rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #5c4a38;
  font-size: 25rpx;
  font-weight: 600;
}

.sub-filter-btn text:first-child {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sub-filter-btn.active,
.sub-filter-btn.selected {
  border-color: #f0b693;
  background: #fff0e7;
  color: #e8723c;
}

.filter-arrow {
  color: #a69682;
  font-size: 24rpx;
  line-height: 1;
  flex-shrink: 0;
}

.filter-panel {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 152rpx;
  z-index: 30;
  padding: 22rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 28rpx;
  background: #fffdf7;
  box-shadow: 0 18rpx 48rpx rgba(45, 35, 24, 0.12);
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.filter-option {
  height: 56rpx;
  padding: 0 22rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  color: #5c4a38;
  font-size: 25rpx;
  font-weight: 600;
}

.filter-option.selected {
  border-color: #e8723c;
  background: #e8723c;
  color: #ffffff;
}

.roommate-scroll {
  flex: 1;
  height: calc(100vh - 168rpx);
}

.review-queue {
  display: grid;
  gap: 16rpx;
  padding: 8rpx 32rpx 12rpx;
}

.review-card {
  padding: 22rpx 26rpx;
  border: 1rpx solid rgba(232, 137, 74, 0.28);
  border-radius: 26rpx;
  background: #fff8ef;
  box-shadow: 0 8rpx 24rpx rgba(232, 137, 74, 0.07);
}

.review-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.review-title text:first-child {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #2d2318;
  font-size: 28rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-badge {
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #e8723c;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 34rpx;
  flex-shrink: 0;
}

.review-desc {
  display: block;
  margin-top: 8rpx;
  color: #5c4a38;
  font-size: 24rpx;
  line-height: 1.45;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 8rpx 32rpx calc(156rpx + env(safe-area-inset-bottom));
}

.post-card {
  padding: 30rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 32rpx;
  background: #fffdf7;
  box-shadow: 0 10rpx 28rpx rgba(45, 35, 24, 0.04);
  transition: transform 0.16s ease, box-shadow 0.16s ease;
}

.post-card:active {
  transform: scale(0.985);
  box-shadow: 0 6rpx 18rpx rgba(45, 35, 24, 0.05);
}

.post-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.post-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.av-male {
  background: linear-gradient(135deg, #8cb0c8, #6c90a8);
}

.av-female {
  background: linear-gradient(135deg, #e8a0b0, #d08090);
}

.post-user {
  flex: 1;
  min-width: 0;
}

.post-username {
  color: #2d2318;
  font-size: 32rpx;
  font-weight: 650;
}

.post-meta {
  margin-top: 4rpx;
  color: #8c7a68;
  font-size: 24rpx;
}

.post-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 650;
  flex-shrink: 0;
  max-width: 210rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-badge text {
  margin-left: 8rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  background: #e8723c;
  color: #ffffff;
  font-size: 20rpx;
}

.has-room {
  background: rgba(91, 154, 111, 0.12);
  color: #5b9a6f;
}

.need-room {
  background: rgba(91, 140, 184, 0.12);
  color: #5b8cb8;
}

.post-title {
  color: #2d2318;
  font-size: 34rpx;
  font-weight: 650;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-desc {
  margin-top: 12rpx;
  color: #5c4a38;
  font-size: 28rpx;
  line-height: 1.5;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.post-tags text {
  height: 44rpx;
  max-width: 220rpx;
  padding: 0 16rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 999rpx;
  color: #8c7a68;
  font-size: 22rpx;
  line-height: 44rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.roommate-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 128rpx 40rpx;
  text-align: center;
  color: #8c7a68;
  font-size: 28rpx;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 22rpx;
  border-radius: 50%;
  background: #fffdf7;
  color: #e8e0d4;
  font-size: 72rpx;
  box-shadow: inset 0 0 0 1rpx #f0eae0;
}

.empty-title {
  color: #2d2318;
  font-size: 32rpx;
  font-weight: 650;
}

.empty-copy {
  max-width: 420rpx;
  margin-top: 10rpx;
  color: #8c7a68;
  font-size: 26rpx;
  line-height: 1.5;
}

.float-pub {
  position: fixed;
  right: 32rpx;
  bottom: calc(42rpx + env(safe-area-inset-bottom));
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  min-width: 104rpx;
  min-height: 104rpx;
  max-width: 104rpx;
  max-height: 104rpx;
  padding: 0;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e8723c;
  color: #ffffff;
  box-shadow: 0 16rpx 44rpx rgba(232, 114, 60, 0.34);
  transition: transform 0.16s ease;
}

.float-pub text {
  display: block;
  width: 104rpx;
  height: 104rpx;
  color: #ffffff;
  font-size: 60rpx;
  font-weight: 700;
  line-height: 100rpx;
  text-align: center;
}

.float-pub:active {
  transform: scale(0.92);
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  background: rgba(45, 35, 24, 0.28);
}

.post-sheet,
.detail-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  max-height: 84vh;
  padding: 32rpx 36rpx calc(36rpx + env(safe-area-inset-bottom));
  border-radius: 48rpx 48rpx 0 0;
  background: #fffdf7;
  box-shadow: 0 -28rpx 72rpx rgba(45, 35, 24, 0.18);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: -12rpx auto 22rpx;
  border-radius: 999rpx;
  background: #e8e0d4;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.sheet-title {
  color: #2d2318;
  font-size: 40rpx;
  font-weight: 700;
}

.sheet-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #fef8ef;
  color: #5c4a38;
  font-size: 38rpx;
  flex-shrink: 0;
}

.segment {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.segment button {
  height: 72rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 999rpx;
  color: #2d2318;
  font-size: 26rpx;
  font-weight: 650;
}

.segment button.active {
  border-color: #e8723c;
  background: #e8723c;
  color: #ffffff;
}

.form-scroll {
  max-height: 54vh;
}

.form-grid {
  display: grid;
  gap: 20rpx;
}

.field {
  display: grid;
  gap: 10rpx;
}

.field text {
  color: #5c4a38;
  font-size: 26rpx;
  font-weight: 650;
}

.field input,
.field textarea {
  min-height: 82rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 24rpx;
  background: #fafaf6;
  color: #2d2318;
  font-size: 28rpx;
}

.input-placeholder {
  color: #a69682;
}

.field textarea {
  height: 150rpx;
  padding-top: 22rpx;
  line-height: 1.45;
}

.confirm-field {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 114, 60, 0.2);
  border-radius: 24rpx;
  background: #fff8f2;
  color: #5c4a38;
  font-size: 26rpx;
  line-height: 1.45;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.cancel-btn,
.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 84rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 650;
}

.cancel-btn {
  background: #fef8ef;
  color: #5c4a38;
}

.submit-btn {
  background: #e8723c;
  color: #ffffff;
}

.cancel-btn:active,
.submit-btn:active {
  opacity: 0.86;
}

.detail-sheet {
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
}

.detail-panel {
  padding: 24rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 28rpx;
  background: #fafaf6;
}

.detail-user {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.detail-user-main {
  flex: 1;
  min-width: 0;
}

.detail-user-main view {
  color: #2d2318;
  font-size: 32rpx;
  font-weight: 650;
}

.detail-user-main text {
  display: block;
  margin-top: 6rpx;
  color: #8c7a68;
  font-size: 24rpx;
  line-height: 1.4;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #f0eae0;
}

.detail-row text {
  color: #8c7a68;
  font-size: 26rpx;
  flex-shrink: 0;
}

.detail-row view {
  min-width: 0;
  color: #2d2318;
  font-size: 26rpx;
  line-height: 1.45;
  text-align: right;
}

.contact-box {
  margin-top: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(232, 114, 60, 0.2);
  border-radius: 24rpx;
  background: #fff8f2;
  color: #5c4a38;
  font-size: 26rpx;
  line-height: 1.5;
}

.contact-box text:first-child {
  display: block;
  margin-bottom: 8rpx;
  color: #2d2318;
  font-weight: 650;
}

.contact-box view {
  margin-bottom: 8rpx;
  color: #e8723c;
  font-weight: 650;
}

.contact-box text:last-child {
  color: #8c7a68;
}
