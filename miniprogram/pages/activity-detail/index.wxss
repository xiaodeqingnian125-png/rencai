.detail-page {
  min-height: 100vh;
  padding-bottom: 150rpx;
  background: #fafaf6;
}

.hero {
  position: relative;
  height: 380rpx;
}

.cover-grad-1 {
  background: linear-gradient(135deg, #f5e8d8 0%, #e8d4b8 42%, #dcc8a0 100%);
}

.cover-grad-2 {
  background: linear-gradient(135deg, #e8f0e8 0%, #d0e0d0 42%, #bcd0bc 100%);
}

.cover-grad-3 {
  background: linear-gradient(135deg, #f0e8f0 0%, #ddd0e0 42%, #cbc0d0 100%);
}

.cover-grad-4 {
  background: linear-gradient(135deg, #e6eef2 0%, #cddce4 48%, #b7cad5 100%);
}

.hero-badge {
  position: absolute;
  left: 32rpx;
  top: 32rpx;
  height: 44rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.badge-official {
  background: #e8723c;
}

.badge-user {
  background: #5b9a6f;
}

.hero-date {
  position: absolute;
  right: 34rpx;
  bottom: 36rpx;
  color: rgba(45, 35, 24, 0.74);
  font-size: 68rpx;
  font-weight: 800;
}

.content {
  padding: 34rpx 32rpx 30rpx;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.title {
  flex: 1;
  color: #2d2318;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
}

.status {
  flex-shrink: 0;
  padding-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.status-open {
  color: #5b9a6f;
}

.status-full {
  color: #8c7a68;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 30rpx;
}

.info-cell {
  min-width: 0;
  padding: 24rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 24rpx;
  background: #fffdf7;
}

.info-cell text {
  display: block;
  margin-bottom: 8rpx;
  color: #a69682;
  font-size: 24rpx;
}

.info-cell view {
  color: #2d2318;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 1.35;
}

.section-card {
  margin-top: 24rpx;
  padding: 30rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 28rpx;
  background: #fffdf7;
}

.section-title {
  margin-bottom: 16rpx;
  color: #2d2318;
  font-size: 32rpx;
  font-weight: 700;
}

.paragraph {
  color: #5c4a38;
  font-size: 29rpx;
  line-height: 1.65;
}

.note-row {
  display: flex;
  gap: 14rpx;
  margin-top: 14rpx;
  color: #5c4a38;
  font-size: 28rpx;
  line-height: 1.5;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 16rpx;
  border-radius: 50%;
  background: #e8723c;
  flex-shrink: 0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0eae0;
  background: #fffdf7;
}

.register-btn,
.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: #e8723c;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.register-btn.disabled {
  background: #d8cec0;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  background: rgba(45, 35, 24, 0.32);
}

.form-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  padding: 18rpx 36rpx calc(36rpx + env(safe-area-inset-bottom));
  border-radius: 48rpx 48rpx 0 0;
  background: #fffdf7;
}

.sheet-handle {
  width: 84rpx;
  height: 10rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #e8e0d4;
}

.sheet-title {
  margin-bottom: 22rpx;
  color: #2d2318;
  font-size: 36rpx;
  font-weight: 750;
}

.field {
  margin-bottom: 20rpx;
}

.field text {
  display: block;
  margin-bottom: 10rpx;
  color: #8c7a68;
  font-size: 26rpx;
}

.field input {
  height: 84rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 20rpx;
  background: #fafaf6;
  color: #2d2318;
  font-size: 30rpx;
}
