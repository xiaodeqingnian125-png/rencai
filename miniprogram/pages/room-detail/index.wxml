<view wx:if="{{apartment && room}}" class="room-page">
  <scroll-view class="gallery" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="gallery-img gi-1"></view>
    <view class="gallery-img gi-2"></view>
    <view class="gallery-img gi-3"></view>
  </scroll-view>
  <view class="gallery-counter">1 / 3</view>
  <view class="gallery-nav">
    <button class="nav-btn" bindtap="goBack">‹</button>
    <button class="nav-btn fav {{favorite ? 'on' : ''}}" bindtap="toggleFavorite">♥</button>
  </view>

  <scroll-view class="room-scroll" scroll-y>
    <view class="room-header">
      <view class="room-header-top">
        <view class="room-name">{{room.name}}</view>
        <view class="room-price">{{room.price}}<text>/月起</text></view>
      </view>
      <view class="room-meta-row">
        <text>{{room.area}}</text>
        <text>{{room.orient}}</text>
        <text>{{room.layout}}</text>
        <text>{{room.floor}}</text>
      </view>
    </view>

    <view class="info-block">
      <view class="info-block-title">户型介绍</view>
      <view class="info-text">{{room.desc}}</view>
    </view>

    <view class="info-block">
      <view class="info-block-title">费用信息</view>
      <view class="cost-grid">
        <view wx:for="{{room.costs}}" wx:key="label" class="cost-cell {{item.active ? 'active' : 'inactive'}}">
          <text class="cost-label">{{item.label}}</text>
          <view class="cost-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view class="info-block">
      <view class="info-block-title">配套设施</view>
      <view class="fac-grid">
        <view wx:for="{{room.facilities}}" wx:key="label" class="fac-cell {{item.active ? 'active' : 'inactive'}}">
          <view class="fac-icon">{{item.icon}}</view>
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="info-block">
      <view class="info-block-title">详细参数</view>
      <view class="info-table">
        <view class="info-row"><text>所属公寓</text><view>{{apartment.name}}</view></view>
        <view class="info-row"><text>户型</text><view>{{room.layout}}</view></view>
        <view class="info-row"><text>面积</text><view>{{room.area}}</view></view>
        <view class="info-row"><text>朝向</text><view>{{room.orient}}</view></view>
        <view class="info-row"><text>楼层</text><view>{{room.floor}}</view></view>
        <view class="info-row"><text>租金</text><view class="rent">{{room.price}} 元/月</view></view>
        <view class="info-row"><text>押金</text><view>押一付三</view></view>
        <view class="info-row"><text>入住时间</text><view>随时，审核通过即可签约</view></view>
      </view>
    </view>

    <view class="comment-section">
      <view class="comment-header">
        <view class="info-block-title">住户评价</view>
        <button class="write-btn" bindtap="openCommentSheet">写评价</button>
      </view>
      <view class="comment-list">
        <view wx:for="{{room.comments}}" wx:key="body" class="comment-item">
          <view class="comment-user">
            <view class="comment-avatar {{item.avatarClass}}">{{item.avatar}}</view>
            <text class="comment-name">{{item.name}}</text>
            <text class="comment-time">{{item.time}}</text>
          </view>
          <view class="comment-body">{{item.body}}</view>
          <view class="comment-actions">
            <button data-index="{{index}}" bindtap="likeComment">赞 {{item.likes}}</button>
            <button bindtap="replyComment">回复</button>
          </view>
        </view>
      </view>
    </view>

    <view class="scroll-spacer"></view>
  </scroll-view>

  <view class="bottom-bar">
    <button class="share-btn" open-type="share">分享给朋友</button>
    <button class="bottom-fav {{favorite ? 'on' : ''}}" bindtap="toggleFavorite">♥</button>
  </view>

  <view wx:if="{{commentSheetOpen}}" class="sheet-mask" bindtap="closeCommentSheet"></view>
  <view wx:if="{{commentSheetOpen}}" class="comment-sheet">
    <view class="sheet-grabber"></view>
    <view class="sheet-title">写户型评价</view>
    <view class="sheet-subtitle">仅支持纯文字评价，200 字以内；5 分钟内不可重复提交。</view>
    <textarea
      class="comment-textarea"
      maxlength="200"
      value="{{commentDraft}}"
      placeholder="例如：这个户型住起来最满意和最需要注意的地方是什么？"
      bindinput="handleCommentInput"
    ></textarea>
    <view class="comment-rule">
      <text>纯文字评价</text>
      <text>{{commentCount}}</text>
    </view>
    <view class="sheet-actions">
      <button class="cancel-btn" bindtap="closeCommentSheet">取消</button>
      <button class="submit-btn" bindtap="submitComment">发布评价</button>
    </view>
  </view>
</view>
