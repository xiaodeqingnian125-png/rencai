.form-page {
  min-height: 100vh;
  padding: 28rpx 32rpx 54rpx;
  background: #fafaf6;
}

.form-card {
  padding: 30rpx;
  border: 1rpx solid #f0eae0;
  border-radius: 28rpx;
  background: #fffdf7;
}

.form-title {
  margin-bottom: 24rpx;
  color: #2d2318;
  font-size: 36rpx;
  font-weight: 750;
}

.field {
  margin-bottom: 22rpx;
}

.field text {
  display: block;
  margin-bottom: 10rpx;
  color: #8c7a68;
  font-size: 26rpx;
}

.field input,
.field textarea {
  width: 100%;
  padding: 0 24rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 20rpx;
  background: #fafaf6;
  color: #2d2318;
  font-size: 30rpx;
}

.field input {
  height: 84rpx;
}

.field textarea {
  height: 220rpx;
  padding-top: 22rpx;
  line-height: 1.5;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.seg-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.seg {
  height: 76rpx;
  border: 1rpx solid #e8e0d4;
  border-radius: 18rpx;
  color: #5c4a38;
  font-size: 28rpx;
  font-weight: 650;
}

.seg.active {
  border-color: #e8723c;
  background: #fff0e7;
  color: #e8723c;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: #e8723c;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 750;
}
